        window.pageMetadata = {"categoryId":"Multimedia design","categoryIds":["Multimedia design"],"subcategoryName":"Illustration \u0026 graphic design","approximateSizeInBytes":2927261,"capabilities":[],"developerName":"BassThermal","durationInSeconds":0,"hasAddOns":false,"hasThirdPartyIAPs":false,"language":"neutral","maxInstallSizeInBytes":7401472,"mediaType":"Apps","publisherId":"93486540","ratingCount":0,"additionalLicenseTerms":"","appWebsiteUrl":"https://www.dualticker.com/lab","features":["Convert images with authentic retro hardware-style visual limitations","Create Game Boy-inspired 4-shade handheld looks","Generate NES-style palette-limited retro graphics","Apply SNES-inspired 16-bit era image treatment","Create Commodore 64-style 16-color visuals","Preview retro transformations quickly in a focused desktop workflow","Export polished retro-styled images for art, thumbnails, posts, and creative projects","Built for creators, pixel art fans, game devs, and nostalgic design workflows"],"gamingOptionsXboxLive":false,"installationTerms":"Kry hierdie toepassing terwyl jy by jou Microsoft-rekening aangemeld is en installeer dit op tot tien Windows-toestelle.","isMicrosoftProduct":false,"isMsixvc":false,"lastUpdateDateUtc":"2026-04-24T02:40:41Z","notes":["UI improvements"],"permissionsRequired":["Gebruik alle stelselhulpbronne"],"platforms":["x64"],"privacyUrl":"https://cdn.storeedgefd.dsx.mp.microsoft.com/eus2/privacy-policy-storage/93486540/00013666571791679282/1152921505700895430/privacy_policy_041e076e-2a07-46ff-a95a-a6caae02aa80.txt","productRatings":[{"ratingSystem":"Pan-Europese Speletjie-inligting","ratingSystemShortName":"PEGI","ratingSystemId":"PEGI","ratingSystemUrl":"https://pegi.info","ratingValue":"PEGI 3","ratingId":"PEGI:3","ratingValueLogoUrl":"https://store-images.s-microsoft.com/image/global.4635.image.6f55bab8-d894-46ea-94d9-4ad102009096.4211468b-3c13-4a63-9bd3-07385b207b19","ratingAge":3,"restrictMetadata":false,"restrictPurchase":false,"ratingDescriptors":[],"ratingDisclaimers":[],"interactiveElements":[],"longName":"PEGI 3","shortName":"PEGI 3","description":"Vir ouderdom 3 en ouer","hasInAppPurchases":false}],"publisherCopyrightInformation":"","publisherPhoneNumber":"","packageLastUpdateDateUtc":"2026-04-24T02:40:41Z","supportedLanguages":["Engels (Verenigde State)"],"supportUris":[{"uri":"mailto:scrollarchy@gmail.com"},{"uri":"https://www.dualticker.com/lab"}],"systemRequirements":{"minimum":{"title":"Minimum","items":[{"level":"HardBlock","itemCode":"dvc","name":"Beskikbaar op","description":"Rekenaar","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"OS","description":"Windows 10 weergawe 17763.0 of ho\u00EBr","validationHint":"vereis","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Sleutelbord","description":"Ge\u00EFntegreerde sleutelbord","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"Muis","description":"Ge\u00EFntegreerde muis","priority":"Default"}]},"recommended":{"title":"Aanbeveel","items":[{"level":"HardBlock","itemCode":"dvc","name":"Beskikbaar op","description":"Rekenaar","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"OS","description":"Windows 10 weergawe 17763.0 of ho\u00EBr","validationHint":"vereis","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Sleutelbord","description":"Nie gespesifiseer nie","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"Muis","description":"Nie gespesifiseer nie","priority":"Default"}]}},"version":"","pdpImageUrl":"https://store-images.s-microsoft.com/image/apps.60594.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.1d35f769-ce5d-4060-91fe-9538320d2397","productId":"9nk0mhg9f29r","title":"Retrofy","description":"Requires Microsoft .NET Desktop Runtime 8.0 x64. If it is not already installed, Windows may prompt you to install it before first launch.\n\nRetrofy is a retro image converter for Windows that transforms modern images using authentic classic hardware-style limitations instead of generic \u201Cvintage\u201D filters.\n\nCreate images inspired by the visual rules of systems like the Nintendo Game Boy, NES, SNES, and Commodore 64. Retrofy applies constrained palettes, reduced color counts, retro-style resolution pressure, and era-appropriate image treatment so results feel closer to real old hardware aesthetics rather than a basic color overlay.\n\nWhether you want Game Boy-style monochrome looks, NES-style limited palette art, SNES-inspired 16-bit color treatment, or Commodore 64-style retro computer visuals, Retrofy gives you a fast desktop workflow for exploring and exporting nostalgic graphics.\n\nRetrofy is built for creators, pixel art fans, game developers, modders, thumbnail makers, stream asset designers, and anyone who wants to turn modern images into convincing retro-style artwork.\n\nIncluded retro-inspired targets:\n\u2022 Game Boy-style 4-shade handheld look\n\u2022 NES-style palette-limited console look\n\u2022 SNES-inspired 16-bit era color treatment\n\u2022 Commodore 64-style 16-color home computer look\n\nWhy Retrofy stands out:\n\u2022 Uses hardware-style visual limitations instead of generic retro presets\n\u2022 Fast preview workflow for trying multiple classic looks\n\u2022 Great for retro game art, social posts, thumbnails, wallpapers, and creative experiments\n\u2022 Clean desktop interface focused on load, preview, tweak, and export\n\u2022 Designed for people who want authentic retro vibes with less manual work\n\nIf you are looking for a retro image converter, pixel art filter, Game Boy filter, NES filter, SNES-style image effect, or Commodore 64 image style tool for Windows, Retrofy is built for exactly that workflow.","categories":["Multimedia-ontwerp"],"publisherName":"BassThermal","images":[{"imageType":"logo","backgroundColor":"transparent","foregroundCol