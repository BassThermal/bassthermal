,"ratingAge":0,"restrictMetadata":false,"restrictPurchase":false,"ratingDescriptors":[],"ratingDisclaimers":[],"interactiveElements":[],"longName":"3\u002B","shortName":"3\u002B","description":"Ya\u015F\u0131 3-d\u0259n yuxar\u0131 olanlar \u00FC\u00E7\u00FCn","hasInAppPurchases":false}],"publisherCopyrightInformation":"","publisherPhoneNumber":"","packageLastUpdateDateUtc":"2026-04-24T02:40:41Z","supportedLanguages":["\u0130ngilis (AB\u015E)"],"supportUris":[{"uri":"mailto:scrollarchy@gmail.com"},{"uri":"https://www.dualticker.com/lab"}],"systemRequirements":{"minimum":{"title":"Minimum","items":[{"level":"HardBlock","itemCode":"dvc","name":"\u018Fl\u00E7atand\u0131r","description":"Komp\u00FCter","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"\u018FS","description":"Windows 10 versiyas\u0131 17763.0 v\u0259 ya \u0259n son","validationHint":"laz\u0131mi","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Klaviatura","description":"\u0130nteqrasiya olunmu\u015F Klaviatura","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"Si\u00E7an","description":"\u0130nteqrasiya olunmu\u015F Si\u00E7an","priority":"Default"}]},"recommended":{"title":"T\u00F6vsiy\u0259 olunanlar","items":[{"level":"HardBlock","itemCode":"dvc","name":"\u018Fl\u00E7atand\u0131r","description":"Komp\u00FCter","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"\u018FS","description":"Windows 10 versiyas\u0131 17763.0 v\u0259 ya \u0259n son","validationHint":"laz\u0131mi","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Klaviatura","description":"M\u00FC\u0259yy\u0259n olunmay\u0131b","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"Si\u00E7an","description":"M\u00FC\u0259yy\u0259n olunmay\u0131b","priority":"Default"}]}},"version":"","pdpImageUrl":"https://store-images.s-microsoft.com/image/apps.60594.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.1d35f769-ce5d-4060-91fe-9538320d2397","productId":"9nk0mhg9f29r","title":"Retrofy","description":"Requires Microsoft .NET Desktop Runtime 8.0 x64. If it is not already installed, Windows may prompt you to install it before first launch.\n\nRetrofy is a retro image converter for Windows that transforms modern images using authentic classic hardware-style limitations instead of generic \u201Cvintage\u201D filters.\n\nCreate images inspired by the visual rules of systems like the Nintendo Game Boy, NES, SNES, and Commodore 64. Retrofy applies constrained palettes, reduced color counts, retro-style resolution pressure, and era-appropriate image treatment so results feel closer to real old hardware aesthetics rather than a basic color overlay.\n\nWhether you want Game Boy-style monochrome looks, NES-style limited palette art, SNES-inspired 16-bit color treatment, or Commodore 64-style retro computer visuals, Retrofy gives you a fast desktop workflow for exploring and exporting nostalgic graphics.\n\nRetrofy is built for creators, pixel art fans, game developers, modders, thumbnail makers, stream asset designers, and anyone who wants to turn modern images into convincing retro-style artwork.\n\nIncluded retro-inspired targets:\n\u2022 Game Boy-style 4-shade handheld look\n\u2022 NES-style palette-limited console look\n\u2022 SNES-inspired 16-bit era color treatment\n\u2022 Commodore 64-style 16-color home computer look\n\nWhy Retrofy stands out:\n\u2022 Uses hardware-style visual limitations instead of generic retro presets\n\u2022 Fast preview workflow for trying multiple classic looks\n\u2022 Great for retro game art, social posts, thumbnails, wallpapers, and creative experiments\n\u2022 Clean desktop interface focused on load, preview, tweak, and export\n\u2022 Designed for people who want authentic retro vibes with less manual work\n\nIf you are looking for a retro image converter, pixel art filter, Game Boy filter, NES filter, SNES-style image effect, or Commodore 64 image style tool for Windows, Retrofy is built for exactly that workflow.","categories":["Multimedia dizayn\u0131"],"publisherName":"BassThermal","images":[{"imageType":"logo","backgroundColor":"transparent","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.1141.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.1a596326-c349-493a-b67f-75a0cd6cb2d3","height":50,"width":50},{"imageType":"logo","backgroundColor":"transparent","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.61389.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.d9866852-948e-4aa6-85f2-0284397864ad","height":75,"width":75},{"imageType":"logo","backgroundColor":"transparent","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.49044.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.f66aba71-23c3-4e87-b4e0-047e7589c9db","height":100,"width":100},{"imageType":"tile","backgroundColor":"transparent","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.6523.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.f7d3504f-4ebf-4708-9be7-031fb0769435","height":150,"width":150},{"imageType":"tile","backgroundColor":"transparent","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.60594.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.1d35f769-ce5d-4060-91fe-9538320d2397","height":225,"width":225},{"imageType":"tile","backgroundColor":"transparent","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.56551.13666571791679282.7b35334f-47c1-47ca-a13a-73ac8ec7b958.6c43c670-9777-4585-b384-d2ef525602f3","height":300,"width":300},{"imageType":"tile","backgroundColor":"transpare