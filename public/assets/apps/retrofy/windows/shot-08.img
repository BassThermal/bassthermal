        window.pageLocalizer = {"hl":"az-Latn-AZ","gl":"AZ","uiLocale":"az-Latn-AZ","marketDetails":{"market":"AZ","tier":3},"isEmbargoedMarket":false,"localeStrings":{"AboutPage.DisclaimerPlus":"Ekranlar simulyasiya edildi. X\u00FCsusiyy\u0259tl\u0259r v\u0259 proqram \u0259l\u00E7atanl\u0131\u011F\u0131 b\u00F6lg\u0259 \u00FCzr\u0259 f\u0259rql\u0259n\u0259 bil\u0259r. Ayr\u0131-ayr\u0131l\u0131qda sat\u0131lan proqramlar, oyunlar v\u0259 dig\u0259r m\u0259zmun/abun\u0259likl\u0259r; pulsuz proqramlarda reklamlar v\u0259 ya proqram daxili sat\u0131nalmalar ola bil\u0259r.","AboutPage.DisclaimerOne":"Yaln\u0131z se\u00E7ilmi\u015F regionlara t\u0259tbiq edilir.","AboutPage.DisclaimerTwo":"Store-da proqramlar t\u0259rtibat\u00E7\u0131 t\u0259r\u0259find\u0259n paylan\u0131b ayr\u0131l\u0131qda yenil\u0259nir.","AboutPage.DisclaimerThree":"T\u0259hl\u00FCk\u0259siz \u00F6d\u0259ni\u015F \u00FCsullar\u0131 se\u00E7ilmi\u015F m\u0259zmun v\u0259 proqramlardan as\u0131l\u0131d\u0131r.","AboutPage.SocialApps":"SOS\u0130AL \u015E\u018FB\u018FK\u018F PROQRAMLARI","AboutPage.SocialAppsSubtitle":"Qo\u015Fulun v\u0259 \u00F6yr\u0259nin","AboutPage.ProductivityApps":"M\u018FHSULDARLIQ PROQRAMLARI","AboutPage.ProductivityAppsSubtitle":"\u0130st\u0259nil\u0259n yerd\u0259n daha \u00E7ox \u015Fey \u0259ld\u0259 edin","AboutPage.ClassicGames":"KLASS\u0130K OYUNLAR","AboutPage.ClassicGamesSubtitle":"He\u00E7 vaxt k\u00F6hn\u0259lm\u0259y\u0259c\u0259k klassikl\u0259r","AboutPage.ExploreMore":"Daha \u00C7oxunu Ara\u015Fd\u0131r","AboutPage.ExploreNow":"\u0130ndi ara\u015Fd\u0131r","AboutPage.ImageAlt":"M\u0259lumat bannerinin fon \u015F\u0259kli.","AboutPage.Title":"\u0130\u015F v\u0259 oyun \u00FC\u00E7\u00FCn proqram v\u0259 oyunlar","AboutPage.MetaTitle":"Microsoft Store-da Proqramlar v\u0259 Oyunlar\u0131 A\u015Fkarlay\u0131n v\u0259 Ara\u015Fd\u0131r\u0131n","AboutPage.MetaDescription":"Microsoft Store-da t\u0259hl\u00FCk\u0259siz proqram v\u0259 oyunlar\u0131n geni\u015F se\u00E7imini ara\u015Fd\u0131r\u0131n. T\u0259hl\u00FCk\u0259siz v\u0259 etibarl\u0131 endiriml\u0259r \u00FC\u00E7\u00FCn niy\u0259 m\u0259hz go-to m\u0259kan\u0131 oldu\u011Funu \u00F6yr\u0259nin. Daha \u00E7oxunu a\u015Fkarlay\u0131n!","AboutPage.Number":"{0} s\u0259hif\u0259sin\u0259 abun\u0259 olmaq \u00FC\u00E7\u00FCn ke\u00E7in","AboutPage.GamingTitle":"\u0130\u015F masas\u0131 oyunlar\u0131","AboutPage.GamingDescription":"M\u00FCkafat qazand\u0131ran Indie oyun t\u0259rtibat\u00E7\u0131lar\u0131ndan AAA yay\u0131m\u00E7\u0131lar\u0131na q\u0259d\u0259r komp\u00FCter oyunlar\u0131 oynay\u0131n","AboutPage.ExploreGames":"Oyunlar\u0131 ara\u015Fd\u0131r","AboutPage.ExploreApps":"Proqramlar\u0131 ara\u015Fd\u0131r","AboutPage.RewardsTitle":"Rewards","AboutPage.RewardsDescription":"Endirimli b\u00F6lg\u0259l\u0259rd\u0259 Store-dan m\u0259hsul ald\u0131qda Microsoft Rewards xallar\u0131 qazan\u0131n. Bu xallar\u0131 h\u0259diyy\u0259 kartlar\u0131, ian\u0259l\u0259r v\u0259 udu\u015F oyunlar\u0131nda istifad\u0259 edin.","AboutPage.AiHub":"AI m\u0259rk\u0259zi","AboutPage.AiHubDescription":"M\u0259hsuldarl\u0131\u011F\u0131n\u0131z\u0131 v\u0259 yarad\u0131c\u0131l\u0131\u011F\u0131n\u0131z\u0131 art\u0131rmaq \u00FC\u00E7\u00FCn y\u00FCks\u0259k keyfiyy\u0259tli A\u0130-powered apps \u0259ld\u0259 etm\u0259k \u00FC\u00E7\u00FCn yeni yer","AboutPage.TrustworthyTitle":"Etibarl\u0131 v\u0259 t\u0259hl\u00FCk\u0259siz","AboutPage.TrustworthyDescription":"T\u0259sdiql\u0259nmi\u015F proqramlarla t\u0259hl\u00FCk\u0259siz \u015F\u0259kild\u0259 endirin, bel\u0259likl\u0259, n\u0259 qura\u015Fd\u0131rd\u0131\u011F\u0131n\u0131za etibar ed\u0259 bil\u0259rsiniz","AboutPage.CertificationTitle":"Ciddi yoxlama prosesi","AboutPage.CertificationDescription":"B\u00FCt\u00FCn proqramlar tan\u0131nm\u0131\u015F z\u0259r\u0259rli proqramlar v\u0259 t\u0259hl\u00FCk\u0259sizlik hallar\u0131na qar\u015F\u0131 skanlan\u0131r. Proqram\u0131 \u0259ld\u0259 etm\u0259zd\u0259n \u0259vv\u0259l sizin \u00FC\u00E7\u00FCn uy\u011Funlu\u011Fu yoxlay\u0131r\u0131q.","AboutPage.FamilySafetyTitle":"Ail\u0259 t\u0259hl\u00FCk\u0259sizliyi","AboutPage.FamilySafetyDescription":"Ya\u015Fa uy\u011Fun proqramlar v\u0259 oyunlar \u00FC\u00E7\u00FCn sat\u0131n al\u0131nan m\u00FCdafi\u0259 v\u0259 qorunma il\u0259 u\u015Faqlar v\u0259 yeniyetm\u0259l\u0259r \u00FC\u00E7\u00FCn daha t\u0259hl\u00FCk\u0259siz r\u0259q\u0259mli m\u00FChit yarad\u0131n.","AboutPage.TrustedPaymentTitle":"Qorunan \u0259m\u0259liyyatlar","AboutPage.TrustedPaymentDescription":"\u00D6d\u0259ni\u015F \u00FC\u00E7\u00FCn yeni etibarl\u0131 \u00FCsullar say\u0259sind\u0259 aktivl\u0259rinizi qoruyark\u0259n \u0259m\u0259liyyatlar\u0131n\u0131z\u0131 da t\u0259hl\u00FCk\u0259siz saxlay\u0131n.","AboutPage.ExperienceTitle":"Windows-da q\u00FCsursuz t\u0259cr\u00FCb\u0259","AboutPage.ExperienceDescription":"Microsoft cihazlar\u0131 vasit\u0259sil\u0259 asan qura\u015Fd\u0131rma v\u0259 tez yoxlama","AboutPage.ConnectedAccount":"B\u00FCt\u00FCn cihazlar\u0131n\u0131zdak\u0131 proqramlar","AboutPage.ConnectedAccountDescription":"Store-dan proqram v\u0259 ya oyun sat\u0131nalmalar\u0131 v\u0259 endirm\u0259l\u0259ri Microsoft Hesab\u0131n\u0131zla \u0259laq\u0259l\u0259ndiril\u0259c\u0259k, bel\u0259likl\u0259, bir cihazda m\u0259hsul \u0259ld\u0259 etdiyiniz zaman onu he\u00E7 bir \u0259lav\u0259 \u00F6d\u0259ni\u015F etm\u0259d\u0259n dig\u0259r cihazlar\u0131n\u0131zda b\u0259rpa ed\u0259 bil\u0259rsiniz.","AboutPage.PlayAnywhere":"\u0130st\u0259nil\u0259n yerd\u0259 oynay\u0131n","AboutPage.PlayAnywhereDescription":"Komp\u00FCterinizd\u0259 Microsoft Store-dan sat\u0131n al\u0131nm\u0131\u015F i\u015Ftirak\u00E7\u0131 oyunlar\u0131 he\u00E7 bir \u0259lav\u0259 \u00F6d\u0259ni\u015F etm\u0259d\u0259n Xbox-da qura\u015Fd\u0131ra bil\u0259rsiniz. Bunun \u0259ksi d\u0259 do\u011Frudur: Xbox konsolunuzda sat\u0131n al\u0131nm\u0131\u015F endirimli oyunlar komp\u00FCterinizd\u0259 d\u0259 qura\u015Fd\u0131r\u0131la bil\u0259r.","AboutPage.EfficientUpdates":"Effektiv yenil\u0259m\u0259l\u0259r","AboutPage.EfficientUpdatesDescription":"Proqramlar\u0131n fonda bel\u0259 Store-dan effektiv \u015F\u0259kild\u0259 yenil\u0259m\u0259l\u0259r ald\u0131\u011F\u0131na \u0259min olmaq \u00FC\u00E7\u00FCn Microsoft Store v\u0259 Windows birg\u0259 i\u015Fl\u0259yir","AboutPage.DiscoverTitle":"A\u015Fkarla","AboutPage.DiscoverDescription":"Sevdiyiniz media yay\u0131m\u0131 proqram\u0131ndan \u015Foular\u0131 izl\u0259yin, yarad\u0131c\u0131l\u0131q proqram\u0131 il\u0259 r\u0259q\u0259mli inc\u0259s\u0259n\u0259t haz\u0131rlay\u0131n v\u0259 ya g\u00FCcl\u00FC m\u0259hsuldarl\u0131q al\u0259tl\u0259ri il\u0259 i\u015Fi tamamlay\u0131n","AboutPage.Description":"Sevimli proqramlar\u0131n\u0131z\u0131 tap\u0131n. Rahatlay\u0131n, yarad\u0131c\u0131l\u0131q v\u0259 m\u0259hsuldarl\u0131\u011F\u0131n\u0131z\u0131 ortaya \u00E7\u0131xar\u0131n.","AboutPage.Banner.Title":"\u0130st\u0259diyiniz h\u0259r \u015Fey m\u0259hz ist\u0259diyiniz yerd\u0259dir","AboutPage.Banner.ToStoreAppLabel":"\u0130ndi ara\u015Fd\u0131r","AboutPage.MicrosoftStoreTitle":"Microsoft Store Proqram\u0131","AboutPage.MicrosoftStoreDescription":"Windows-da proqram v\u0259 oyunlar\u0131 k\u0259\u015Ff etm\u0259k v\u0259 yenil\u0259m\u0259k \u00FC\u00E7\u00FCn daha yax\u015F\u0131 t\u0259cr\u00FCb\u0259 \u00FC\u00E7\u00FCn Microsoft Store proqram\u0131n\u0131 \u0259ld\u0259 edin.","AboutPage.MicrosoftStoreLogoAlt":"Microsoft Store Loqosu","AboutPage.DownloadStoreButton":"Store proqram\u0131n\u0131 endir","AboutPage.GetStoreAppButton":"Microsoft Store Proqram\u0131n\u0131 \u0259ld\u0259 edin","AboutPage.NoStoreQuestion":"Cihaz\u0131n\u0131zda Microsoft Store proqram\u0131 yoxdur?","AboutPage.DownloadStorePromptLine1":"Cihaz\u0131n\u0131zda Microsoft Store proqram\u0131 yoxdursa,","AboutPage.DownloadStorePromptLine2":"endirm\u0259k \u00FC\u00E7\u00FCn {0} se\u00E7imin\u0259 klikl\u0259yin.","AboutPage.DownloadStoreLink":"burada","AboutPage.SeamlessExperience":"Windows cihazlar\u0131n\u0131zda","AboutPage.TrustedDownload":"Etibarl\u0131 Endirm\u0259l\u0259r","AboutPage.AIIntegrated":"AI \u0130nteqrasiya Edildi","AboutPage.AutomaticUpdates":"Avto Yenil\u0259nm\u0259","AboutPage.TrustedDownloadText":"T\u0259hl\u00FCk\u0259siz","AboutPage.AIIntegratedText":"Copilot","AgeVerification.MatureContentSignInRestriction":"Bu m\u0259zmuna baxmaq \u00FC\u00E7\u00FCn daxil olun","AgeVerification.MatureContentSignInSubtitle":"Bu m\u0259zmunun ya\u015Fa uy\u011Fun olmas\u0131n\u0131 t\u0259min etm\u0259k \u00FC\u00E7\u00FCn ya\u015F\u0131n\u0131z\u0131 yoxlamal\u0131y\u0131q.","AgeVerification.MatureContentSignInButton":"Daxil ol","AgeVerification.MatureContentUnverifiedRestriction":"Bu m\u0259zmunu g\u00F6rm\u0259k \u00FC\u00E7\u00FCn ya\u015F\u0131n\u0131z\u0131 t\u0259sdiql\u0259yin","AgeVerification.MatureContentUnverifiedSubtitle":"Ya\u015F m\u0259hdudiyy\u0259ti olan m\u0259zmuna baxmazdan \u0259vv\u0259l hesab\u0131n\u0131z ya\u015F t\u0259sdiql\u0259nm\u0259sini t\u0259l\u0259b edir.","AgeVerification.MatureContentUnverifiedButton":"Yoxla","AgeVerification.MatureContentRestriction":"Hesab\u0131n\u0131z bu m\u0259zmuna baxmaq \u00FC\u00E7\u00FCn minimum ya\u015F t\u0259l\u0259bl\u0259rin\u0259 cavab vermir.","BuyBox.Tooltip.SignInRequired":"Bu proqram\u0131 \u0259ld\u0259 etm\u0259k \u00FC\u00E7\u00FCn daxil olmal\u0131s\u0131n\u0131z.","BuyBox.Tooltip.AgeBlocked":"Hesab\u0131n\u0131z bu m\u0259hsul \u00FC\u00E7\u00FCn ya\u015F t\u0259l\u0259bl\u0259rin\u0259 cavab vermir.","BuyBox.Tooltip.VerifyRequired":"Bu proqram\u0131 \u0259ld\u0259 etm\u0259k \u00FC\u00E7\u00FCn ya\u015F\u0131n\u0131z\u0131 t\u0259sdiql\u0259m\u0259lisiniz.","AlertService.Retry":"Yenid\u0259n s\u0131na","AlertService.SwitchAccount":"Hesab\u0131 d\u0259yi\u015F","AuthService.SignInError":"X\u0259ta il\u0259 qar\u015F\u0131la\u015Fd\u0131q. Yenid\u0259n c\u0259hd et.","AuthService.PopupBlockedError":"Daxil olmaq \u00FC\u00E7\u00FCn bu saytda peyda olan p\u0259ncc\u0259r\u0259 blokerinizin qeyri-aktiv oldu\u011Fundan \u0259min olun.","AuthRedirect.Title":"\u00C7\u0131x\u0131l\u0131b","AuthRedirect.Description":"\u0130ndi hesabdan \u00E7\u0131xm\u0131s\u0131n\u0131z.","BadgePage.AppID.Header":"Proqram \u0130dentifikasiyas\u0131","BadgePage.AppID.Invalid.Tooltip":"M\u0259hsulun ID-si 12 simvoldan ibar\u0259t olmal\u0131d\u0131r, ID XP il\u0259 ba\u015Flamasa, bu halda 14 simvol olmal\u0131d\u0131r.","BadgePage.AppID.Tooltip":"Proqram\u0131n\u0131z\u0131n \u0130dentifikasiyas\u0131. Bunu Microsoft T\u0259r\u0259fda\u015Flar M\u0259rk\u0259zind\u0259 v\u0259 ya bu saytda proqram URL-nin sonu kimi (m\u0259s. https://apps.microsoft.com/detail/9MV0B5HZVK9Z) tapa bil\u0259rsiniz","BadgePage.AutoLaunch.Header":"Avtomatik i\u015F\u0259salma","BadgePage.AutoLaunch.Tooltip":"Ba\u015Flatma Rejimi Tamd\u0131rsa v\u0259 Avtomatik Ba\u015Flatma do\u011Frudursa, ni\u015Fana klikl\u0259dikd\u0259 Store proqram\u0131 avtomatik a\u00E7\u0131lacaq.","BadgePage.BadgeText":"Proqramlar\u0131 Microsoft Store-dan endirin","BadgePage.ButtonAriaLabel":"{0} d\u00FCym\u0259si","BadgePage.CID.Header":"Kampaniya \u0130dentifikasiyas\u0131","BadgePage.CID.Tooltip":"Proqram\u0131n\u0131z\u0131n kampaniya kodu. Bunu Microsoft Partner Center-d\u0259 tapa bil\u0259rsiniz.","BadgePage.Description":"Microsoft Store proqram ni\u015Fan\u0131 aktivl\u0259rinizd\u0259n Microsoft Store siyah\u0131s\u0131na q\u0259d\u0259r trafiki n\u00FCmayi\u015F etdirm\u0259k, istiqam\u0259tl\u0259ndirm\u0259k v\u0259 izl\u0259m\u0259k \u00FC\u00E7\u00FCn \u0259n yax\u015F\u0131 vasit\u0259dir.","BadgePage.UpdateDescription":"YEN\u0130L\u018FM\u018F: \u0130\u015F\u0259salma s\u0259thi d\u0259sti olmayan eynilik kartlar\u0131 indi birba\u015Fa y\u00FCkl\u0259m\u0259 n\u00F6v\u00FC \u00FC\u00E7\u00FCn standart olacaq. Avtomatik i\u015F\u0259salma se\u00E7imi birba\u015Fa y\u00FCkl\u0259m\u0259l\u0259r \u00FC\u00E7\u00FCn \u0259l\u00E7atmaz olacaq. \u0022Peyda olan menyu\u0022 n\u00F6v\u00FCnd\u0259n istifad\u0259 ed\u0259n m\u00F6vcud JavaScript-\u0259 \u0259saslanan eynilik kartlar\u0131 da birba\u015Fa y\u00FCkl\u0259m\u0259 n\u00F6v\u00FC \u00FC\u00E7\u00FCn standart olacaq.","BadgePage.UpdatePopupDescription":"Peyda olan Store-dan istifad\u0259 etm\u0259y\u0259 davam etm\u0259k \u00FC\u00E7\u00FCn eynilik kart\u0131n\u0131 yenid\u0259n yarad\u0131n v\u0259 yeni kodu istifad\u0259 edin.","BadgePage.Preview.Tab":"\u00D6nbax\u0131\u015F","BadgePage.CodeSnippet.Tab":"Kod Fraqmenti","BadgePage.Optional.Text":"(\u0130xtiyari)","BadgePage.Interaction.Header":"Qar\u015F\u0131l\u0131ql\u0131 \u0259laq\u0259 animasiyas\u0131","BadgePage.Interaction.Tooltip":"\u00DCz\u0259rind\u0259 v\u0259 bas\u0131l\u0131 v\u0259ziyy\u0259td\u0259 olan ni\u015Fan animasiyas\u0131.","BadgePage.Language.Header":"Dil","BadgePage.StaticLanguage.Tooltip":"Emblemi g\u00F6st\u0259rm\u0259k \u00FC\u00E7\u00FCn dil se\u00E7in.","BadgePage.WebComponentLanguage.Tooltip":"Avtomatik a\u015Fkarlama (t\u00F6vsiy\u0259 olunur) ni\u015Fan\u0131 istifad\u0259\u00E7inin brauzer dilind\u0259 \u0259ks etdirir. Ba\u015Fqa s\u00F6zl\u0259, ni\u015Fan\u0131 h\u0259r zaman \u0259ks etdir\u0259 bil\u0259c\u0259yimiz dil se\u00E7in.","BadgePage.Launch.Header":"\u0130\u015F\u0259 salma Rejimi","BadgePage.Launch.Tooltip":"\u0130stifad\u0259\u00E7il\u0259r eynilik kart\u0131n\u0131z\u0131n \u00FCz\u0259rin\u0259 klikl\u0259dikd\u0259 proqram\u0131n\u0131z \u00FC\u00E7\u00FCn i\u015F\u0259salma rejimi. Birba\u015Fa rejim proqram\u0131n\u0131z\u0131n qura\u015Fd\u0131ran\u0131n\u0131 y\u00FCkl\u0259yir v\u0259 standartd\u0131r. Tam rejim proqram\u0131n\u0131z\u0131n m\u0259hsul s\u0259hif\u0259sini Store proqram\u0131nda a\u00E7\u0131r.","BadgePage.WebComponent.Tab":"Veb Komponent","BadgePage.TabAriaLabel":"{0} tab-v\u0259r\u0259q\u0259","BadgePage.TabSelectedAriaLabel":"{0} tab-v\u0259r\u0259q\u0259 se\u00E7ilib","BadgePage.Theme.Header":"M\u00F6vzu","BadgePage.StaticTheme.Tooltip":"\u0130stifad\u0259 olunacaq emblem m\u00F6vzusu. T\u00F6vsiy\u0259 olunur ki, a\u00E7\u0131q fonda t\u00FCnd, t\u00FCnd fonda is\u0259 a\u00E7\u0131q m\u00F6vzu se\u00E7ilsin.","BadgePage.WebComponentTheme.Tooltip":"Avtomatik Tan\u0131ma istifad\u0259\u00E7inin temas\u0131n\u0131 a\u015Fkar ed\u0259c\u0259k v\u0259 m\u00FCvafiq ni\u015Fan temas\u0131n\u0131 g\u00F6st\u0259r\u0259c\u0259k.","BadgePage.Title":"Proqram ni\u015Fan\u0131n\u0131z\u0131 qurun","BadgePage.Tooltip":"Al\u0259t izah\u0131.","BadgePage.Guidelines.Tooltip":"T\u0259limatlar","BadgePage.False.Option":"Yalan","BadgePage.True.Option":"Do\u011Fru","BadgePage.Direct.Option":"Birba\u015Fa","BadgePage.Full.Option":"Tam","BadgePage.None.Option":"He\u00E7 biri","BadgePage.Dark.Option":"Qaranl\u0131q","BadgePage.Light.Option":"\u0130\u015F\u0131ql\u0131","BadgePage.Off.Option":"Qeyri-aktivdir","BadgePage.On.Option":"Aktivdir","BadgePage.AutoDetect.Option":"Avtomatik A\u015Fkarlama","BadgePage.GenerateBadge":"Eynilik kart\u0131n\u0131z\u0131 yarad\u0131n","BadgePage.CopiedClipboard":"M\u00FCbadil\u0259 buferin\u0259 k\u00F6\u00E7\u00FCr\u00FCld\u00FC!","BadgePage.StaticBadge.Title":"Statik emblem","BadgePage.StaticBadge.SimpleDescription":"Standart \u015F\u0259kil v\u0259 ke\u00E7idd\u0259n istifad\u0259 ed\u0259n sad\u0259, y\u00FCng\u00FCl emblem.","BadgePage.StaticBadge.Description":"Bu ni\u015Fan README-l\u0259r, s\u0259n\u0259dl\u0259\u015Fdirm\u0259 saytlar\u0131, M\u0259zmun T\u0259hl\u00FCk\u0259sizlik Siyas\u0259ti olan m\u00FChitl\u0259r v\u0259 ya xarici skriptl\u0259rin m\u0259hdudla\u015Fd\u0131r\u0131ld\u0131\u011F\u0131 h\u0259r yerd\u0259 ideald\u0131r.\u00A0","BadgePage.WebComponentBadge.Title":"Veb komponent emblemi","BadgePage.WebComponentBadge.SimpleDescription":"Veb komponent kimi haz\u0131rlanm\u0131\u015F dinamik, interaktiv emblem.","BadgePage.WebComponentBadge.Description":"Bu emblem JavaScript \u0259sasl\u0131d\u0131r v\u0259 avtomatik dil v\u0259 m\u00F6vzu a\u015Fkar etm\u0259, h\u0259m\u00E7inin \u00FCz\u0259rind\u0259 saxlama animasiyas\u0131 kimi m\u00FCasir x\u00FCsusiyy\u0259tl\u0259r t\u0259klif edir. \u0130stifad\u0259\u00E7il\u0259riniz \u00FC\u00E7\u00FCn \u0259n yax\u015F\u0131, \u0259n f\u0259rdil\u0259\u015Fdirilmi\u015F t\u0259cr\u00FCb\u0259ni ist\u0259diyiniz zaman bu se\u00E7imi edin.","BadgePage.GetStarted.Title":"\u0130\u015F\u0259 ba\u015Flay\u0131n","BadgePage.GetStarted.Description":"Embleminizi yaratmaq v\u0259 veb-sayt\u0131n\u0131za \u0259lav\u0259 etm\u0259k \u00FC\u00E7\u00FCn bu add\u0131mlar\u0131 izl\u0259yin.","BadgePage.GetStarted.Step1.Title":"Emblem n\u00F6v\u00FC se\u00E7in","BadgePage.GetStarted.Step1.Description":"Veb komponent v\u0259 ya Statik emblem aras\u0131nda se\u00E7im edin. \u018Fmin deyilsinizs\u0259, statik emblem t\u0259hl\u00FCk\u0259siz se\u00E7imdir.","BadgePage.GetStarted.Step2.Title":"Proqram identifikatorunuzu daxil edin","BadgePage.GetStarted.Step2.Description":"12 simvollu Proqram identifikatorunuzu (T\u0259r\u0259fda\u015Flar M\u0259rk\u0259zi al\u0259t panelinizd\u0259 tap\u0131ld\u0131) m\u0259tn qutusuna \u0259lav\u0259 edin.","BadgePage.GetStarted.Step3.Title":"X\u00FCsusiyy\u0259tl\u0259ri se\u00E7in","BadgePage.GetStarted.Step3.Description":"Dili, m\u00F6vzu v\u0259 ba\u015Flatma h\u0259d\u0259fl\u0259rini f\u0259rdil\u0259\u015Fdirin v\u0259 ya performans\u0131 izl\u0259m\u0259k \u00FC\u00E7\u00FCn kampaniya identifikatoru \u0259lav\u0259 edin.","BadgePage.GetStarted.Step4.Title":"Kodu k\u00F6\u00E7\u00FCr\u00FCn","BadgePage.GetStarted.Step4.Description":"\u201CEmblemini yarat\u201D d\u00FCym\u0259sin\u0259 klikl\u0259yin v\u0259 kod fraqmentini birba\u015Fa veb-sayt\u0131n\u0131z\u0131n koduna \u0259lav\u0259 edin.","BadgePage.Guidelines.Title":"T\u0259limatlar v\u0259 \u0259n yax\u015F\u0131 t\u0259cr\u00FCb\u0259l\u0259r","BadgePage.Guidelines.Description":"Konversiya tarifl\u0259rini maksimuma \u00E7atd\u0131rmaq v\u0259 brend uy\u011Funlu\u011Funu qorumaq \u00FC\u00E7\u00FCn bu \u0259n yax\u015F\u0131 t\u0259cr\u00FCb\u0259l\u0259r\u0259 \u0259m\u0259l edin.","BadgePage.Guidelines.KeepItClear.Title":"T\u0259miz saxlay\u0131n","BadgePage.Guidelines.KeepItClear.Description":"Emblemin \u0259traf\u0131nda standart bo\u015Fluq saxlay\u0131n. Onu dig\u0259r m\u0259tn v\u0259 ya qrafik elementl\u0259ri il\u0259 s\u0131x\u0131\u015Fd\u0131rmay\u0131n.","BadgePage.Guidelines.PlaceProminent.Title":"Onu \u00F6n planda yerl\u0259\u015Fdirin","BadgePage.Guidelines.PlaceProminent.Description":"\u018Fn yax\u015F\u0131 reklam\u0131n se\u00E7ilm\u0259si tarifl\u0259ri \u00FC\u00E7\u00FCn emblemi \u0259sas s\u0259hif\u0259nizd\u0259ki \u201Cbro\u015F\u00FCr\u00FCn yuxar\u0131s\u0131nda\u201D yerl\u0259\u015Fdirin v\u0259 ya proqram\u0131n \u0259sas x\u00FCsusiyy\u0259tl\u0259r siyah\u0131s\u0131n\u0131n yan\u0131nda qoyun.","BadgePage.Guidelines.DontAlter.Title":"\u0130nc\u0259s\u0259n\u0259t \u0259s\u0259rini d\u0259yi\u015Fm\u0259yin","BadgePage.Guidelines.DontAlter.Description":"Yarad\u0131lm\u0131\u015F koddan birba\u015Fa istifad\u0259 edin. Emblem qrafikl\u0259rini uzatmay\u0131n, r\u0259ngini d\u0259yi\u015Fm\u0259yin v\u0259 ya modifikasiya etm\u0259yin, \u00E7\u00FCnki bu, Microsoft Store brend t\u0259limatlar\u0131n\u0131 pozur.","BadgePage.Guidelines.CampaignId.Title":"Performans\u0131 izl\u0259m\u0259k \u00FC\u00E7\u00FCn kampaniya identifikatoru \u0259lav\u0259 edin","BadgePage.Guidelines.CampaignId.Description":"Kampaniya identifikatoru \u0259lav\u0259 etm\u0259kl\u0259 ziyar\u0259t\u00E7il\u0259ri v\u0259 konversiyalar\u0131 izl\u0259y\u0259 bil\u0259rsiniz, bu da f\u0259rqli yerl\u0259\u015Fdirm\u0259l\u0259ri s\u0131nama\u011F\u0131 asanla\u015Fd\u0131r\u0131r. Ax\u0131, \u00F6l\u00E7m\u0259diyiniz \u015Feyi t\u0259kmill\u0259\u015Fdirm\u0259yiniz m\u00FCmk\u00FCn deyil!","BadgePage.Guidelines.DownloadLink":"Tam t\u0259limatlar\u0131 y\u00FCkl\u0259yin (PDF)","BadgePage.FAQ.Title":"Tez-tez veril\u0259n suallar","BadgePage.FAQ.FindAppId.Question":"12 simvollu Proqram identifikatorumu (M\u0259hsul identifikatoru) haradan tapa bil\u0259r\u0259m?","BadgePage.FAQ.FindAppId.Answer1":"Proqram\u0131n\u0131z\u0131n identifikatoru (m\u0259hsul identifikatoru kimi d\u0259 tan\u0131n\u0131r) proqrama t\u0259yin edil\u0259n unikal 12 simvollu h\u0259rf v\u0259 r\u0259q\u0259m kodudur. Windows T\u0259r\u0259fda\u015Flar M\u0259rk\u0259zi al\u0259t panelinizd\u0259 tapa bil\u0259rsiniz. Proqram\u0131n\u0131z\u0131n s\u0259hif\u0259sin\u0259 ke\u00E7in, Proqram idar\u0259etm\u0259si \u003E Proqram kimliyi b\u00F6lm\u0259sini se\u00E7in v\u0259 \u0022Ma\u011Faza identifikatoru\u0022 qiym\u0259tini axtar\u0131n.","BadgePage.FAQ.FindAppId.Answer2":"Alternativ olaraq, proqram\u0131n\u0131z\u0131 apps.microsoft.com sayt\u0131nda tapa bil\u0259rsiniz. Proqram identifikatorunuz URL-in sonunda olan 12 simvollu koddur: apps.microsoft.com/detail/\u003CAppID\u003E.","BadgePage.FAQ.TrackDownloads.Question":"Veb-sayt\u0131mdan ne\u00E7\u0259 y\u00FCkl\u0259m\u0259 yarad\u0131ld\u0131\u011F\u0131n\u0131 nec\u0259 izl\u0259y\u0259 bil\u0259r\u0259m?","BadgePage.FAQ.TrackDownloads.Answer":"Emblem ke\u00E7idiniz\u0259 Kampaniya ID-si (cid) \u0259lav\u0259 etm\u0259kl\u0259 emblem m\u0259hsuldarl\u0131\u011F\u0131n\u0131 izl\u0259y\u0259 bil\u0259rsiniz. Yuxar\u0131da embleminizi yaradark\u0259n x\u00FCsusi kampaniya ad\u0131 daxil edin (m\u0259s\u0259l\u0259n, \u0022fooapp_website\u0022). Daha sonra T\u0259r\u0259fda\u015F M\u0259rk\u0259zinin Sat\u0131nalma Hesabat\u0131nda h\u0259min kampaniya il\u0259 \u0259laq\u0259li klikl\u0259m\u0259 nisb\u0259tl\u0259rin\u0259 v\u0259 konversiya veril\u0259nl\u0259rin\u0259 baxa bil\u0259rsiniz.","BadgePage.FAQ.WhichBadgeType.Question":"Hans\u0131 emblem n\u00F6v\u00FCn\u00FC se\u00E7m\u0259liy\u0259m: Statik yoxsa Veb Komponent?","BadgePage.FAQ.WhichBadgeType.Answer1":"M\u00FCasir veb-saytlarda \u0259n yax\u015F\u0131 istifad\u0259\u00E7i t\u0259cr\u00FCb\u0259si \u00FC\u00E7\u00FCn Veb Komponenti se\u00E7in. O, istifad\u0259\u00E7inin sistem dilini avtomatik a\u015Fkar edir, Microsoft-un cari dizayn dilin\u0259 uy\u011Fun yenil\u0259nir v\u0259 hamar \u00FCz\u0259rind\u0259 saxlama animasiyalar\u0131 t\u0259qdim edir.","BadgePage.FAQ.WhichBadgeType.Answer2":"Platforman\u0131z JavaScript-\u0259 m\u0259hdudiyy\u0259t qoyursa (m\u0259s\u0259l\u0259n, GitHub README-l\u0259ri, x\u00FCsusi JS olmayan WordPress v\u0259 ya s\u0259rt M\u0259zmun T\u0259hl\u00FCk\u0259sizlik Siyas\u0259ti m\u00FChitl\u0259ri), Statik emblemi se\u00E7in.","BadgePage.FAQ.UpdateBadge.Question":"Microsoft Store brendini d\u0259yi\u015Fdirs\u0259, emblemi yenil\u0259m\u0259liy\u0259m?","BadgePage.FAQ.UpdateBadge.Answer":"\u018Fg\u0259r bu s\u0259hif\u0259d\u0259n yarad\u0131lan ni\u015Fanlardan istifad\u0259 edirsinizs\u0259, xeyr. Resurslar Microsoft t\u0259r\u0259find\u0259n yerl\u0259\u015Fdirilir v\u0259 embleminiz avtomatik olaraq g\u0259l\u0259c\u0259k brend v\u0259 dizayn d\u0259yi\u015Fiklikl\u0259rin\u0259 uy\u011Fun yenil\u0259n\u0259c\u0259k.","BadgePage.FAQ.ResizeBadge.Question":"Emblemin \u00F6l\u00E7\u00FCs\u00FCn\u00FC veb-sayt\u0131n\u0131z\u0131n dizayn\u0131na uy\u011Fun d\u0259yi\u015Fdir\u0259 bil\u0259r\u0259m?","BadgePage.FAQ.ResizeBadge.Answer":"Veb Komponent emblemi t\u0259bii olaraq cavabdehdir v\u0259 uy\u011Fun \u00F6l\u00E7\u00FCd\u0259 t\u0259nziml\u0259n\u0259c\u0259k. Statik t\u0259svird\u0259n istifad\u0259 edirsinizs\u0259, t\u0259sviri CSS vasit\u0259sil\u0259 (m\u0259s\u0259l\u0259n, maxsimum eni t\u0259nziml\u0259m\u0259kl\u0259) miqyaslaya bil\u0259rsiniz, lakin orijinal aspekt nisb\u0259tini qorumal\u0131s\u0131n\u0131z. T\u0259sviri he\u00E7 vaxt dartmay\u0131n, \u0259ym\u0259yin v\u0259 ya k\u0259sm\u0259yin.","BadgePage.FAQ.DarkMode.Question":"Emblem qaranl\u0131q rejmi d\u0259st\u0259kl\u0259yir?","BadgePage.FAQ.DarkMode.Answer":"B\u0259li. Veb Komponent ni\u015Fan\u0131 istifad\u0259\u00E7inin siste