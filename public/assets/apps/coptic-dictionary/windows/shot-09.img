        window.pageMetadata = {"shortDescription":"Offline Coptic dictionary and study app. Search words and meanings, save vocabulary, quiz yourself, and export study lists.","categoryId":"Education","categoryIds":["Education"],"subcategoryName":"Language","approximateSizeInBytes":4421095,"capabilities":[],"developerName":"BassThermal","durationInSeconds":0,"hasAddOns":false,"hasThirdPartyIAPs":false,"language":"neutral","maxInstallSizeInBytes":20533248,"mediaType":"Apps","publisherId":"93486540","ratingCount":0,"additionalLicenseTerms":"App \u00A9 BassThermal Labs. Lexicon data adapted from Comprehensive Coptic Lexicon v1.2, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","appWebsiteUrl":"https://www.dualticker.com/","features":["Offline Coptic dictionary search","Search by Coptic word, English meaning, or type-as spelling","Save vocabulary for later study","Quiz yourself on saved words","View word forms, dialect labels, sources, and Greek-origin references","Export saved words as CSV, TSV, JSON, Anki CSV, text, or printable study sheet","Import and restore saved-word backups","Copy words, meanings, citations, and study summaries","Keyboard navigation for fast dictionary browsing","Built from the Comprehensive Coptic Lexicon v1.2","No account required; searches stay on your device"],"gamingOptionsXboxLive":false,"installationTerms":"Faigh an feidhmchl\u00E1r agus t\u00FA s\u00EDnithe isteach i do chuntas Microsoft agus suite\u00E1il \u00E9 ar suas le 10 ngl\u00E9as Windows.","isMicrosoftProduct":false,"isMsixvc":false,"lastUpdateDateUtc":"2026-04-30T12:31:39Z","permissionsRequired":["\u00DAs\u00E1ideann s\u00E9 gach acmhainn c\u00F3rais"],"platforms":["x64"],"privacyUrl":"https://cdn.storeedgefd.dsx.mp.microsoft.com/eus2/privacy-policy-storage/93486540/00014493098251600575/1152921505700937663/privacy_policy_9af2b326-0539-4fc9-94ca-e835940d6971.txt","productRatings":[{"ratingSystem":"Pan European Game Information","ratingSystemShortName":