        window.pageLocalizer = {"hl":"ga-IE","gl":"IE","uiLocale":"ga-IE","marketDetails":{"market":"IE","tier":2},"isEmbargoedMarket":false,"localeStrings":{"AboutPage.DisclaimerPlus":"Sc\u00E1ile\u00E1in ionsamhlaithe. F\u00E9adfaidh gn\u00E9ithe agus infhaighteacht feidhmchl\u00E1ir a bheith \u00E9ags\u00FAil de r\u00E9ir r\u00E9igi\u00FAin. Feidhmchl\u00E1ir, cluich\u00ED, agus \u00E1bhar/s\u00EDnti\u00FAis eile a dh\u00EDoltar ar leithligh; f\u00E9adfaidh f\u00F3gra\u00ED n\u00F3 ceannach\u00E1in sa fheidhmchl\u00E1r a bheith i bhfeidhmchl\u00E1ir saor in aisce.","AboutPage.DisclaimerOne":"N\u00ED bhaineann s\u00E9 seo ach le r\u00E9igi\u00FAin roghnaithe.","AboutPage.DisclaimerTwo":"Feidhmchl\u00E1ir sna Store a dh\u00E1ileann a fhorbr\u00F3ir f\u00E9in, nuashonra\u00EDonn an forbr\u00F3ir sin iad ar leithligh.","AboutPage.DisclaimerThree":"Braitheann modhanna \u00EDoca\u00EDochta sl\u00E1na ar an inneachar agus ar fheidhmchl\u00E1ir roghnaithe.","AboutPage.SocialApps":"FEIDHMCHL\u00C1IR L\u00CDONRAITHE SH\u00D3ISIALTA","AboutPage.SocialAppsSubtitle":"Nasc agus foghlaim","AboutPage.ProductivityApps":"FEIDHMCHL\u00C1IR TH\u00C1IRGI\u00DALACHTA","AboutPage.ProductivityAppsSubtitle":"Bain amach tuilleadh \u00F3 \u00E1it ar bith","AboutPage.ClassicGames":"CLUICH\u00CD CLASAICEACHA","AboutPage.ClassicGamesSubtitle":"Clasaicigh nach n-im\u00EDonn in aois riamh","AboutPage.ExploreMore":"D\u00E9an ini\u00FAchadh ar n\u00EDos m\u00F3","AboutPage.ExploreNow":"Taisc\u00E9al anois","AboutPage.ImageAlt":"\u00CDomh\u00E1 ch\u00FAlra den meirge faisn\u00E9ise.","AboutPage.Title":"Feidhmchl\u00E1ir agus cluich\u00ED don obair agus don spraoi","AboutPage.MetaTitle":"Aimsigh agus f\u00E9ach ar fheidhmchl\u00E1ir agus ar chluich\u00ED ag Microsoft Store","AboutPage.MetaDescription":"Taisc\u00E9al rogha thapa d\u0027fheidhmchl\u00E1ir agus de chluich\u00ED sl\u00E1na ag an Microsoft Store. Faigh amach c\u00E9n f\u00E1th go mbainfear an sprioc le h\u00EDosl\u00F3d\u00E1lacha sl\u00E1na iontaofa a dh\u00E9anamh. Faigh amach tuilleadh inniu!","AboutPage.Number":"L\u00E9im chuig foscript {0}","AboutPage.GamingTitle":"Cluich\u00EDocht deisce","AboutPage.GamingDescription":"Imir cluich\u00ED r\u00EDomhaire pearsanta \u00F3 fhorbr\u00F3ir\u00ED cluich\u00ED indie agus foilsitheoir\u00ED AAA a bhfuil duaiseanna buaite acu","AboutPage.ExploreGames":"F\u00E9ach ar chluich\u00ED","AboutPage.ExploreApps":"F\u00E9ach thart ar fheidhmchl\u00E1ir","AboutPage.RewardsTitle":"Rewards","AboutPage.RewardsDescription":"Tuill point\u00ED Microsoft Rewards nuair a cheanna\u00EDonn t\u00FA t\u00E1irg\u00ED \u00F3n Store sna r\u00E9igi\u00FAin rannph\u00E1irteacha. Fuascail point\u00ED le haghaidh iontr\u00E1lacha c\u00E1rta\u00ED bronntanais, deonach\u00E1in agus scuabtha.","AboutPage.AiHub":"Mol AI","AboutPage.AiHubDescription":"\u00C1it nua chun feidhmchl\u00E1ir ardchaighde\u00E1in-chumhachtaithe AI a fh\u00E1il chun do th\u00E1irgi\u00FAlacht agus do chruthaitheacht a treisi\u00FA","AboutPage.TrustworthyTitle":"Iontaofa agus sl\u00E1n","AboutPage.TrustworthyDescription":"\u00CDosl\u00F3d\u00E1il go s\u00E1bh\u00E1ilte le feidhmchl\u00E1ir fh\u00EDoraithe, ionas gur f\u00E9idir leat muin\u00EDn a bheith agat as an m\u00E9id a shuite\u00E1lann t\u00FA","AboutPage.CertificationTitle":"Pr\u00F3iseas f\u00EDoraithe dian","AboutPage.CertificationDescription":"Scantar gach feidhmchl\u00E1r i gcomhair fadhbanna bogearra\u00ED mail\u00EDseacha agus sl\u00E1nd\u00E1la. Seice\u00E1laimid comhoiri\u00FAnacht feidhmchl\u00E1ir duit sula bhfaigheann t\u00FA an feidhmchl\u00E1r.","AboutPage.FamilySafetyTitle":"S\u00E1bh\u00E1ilteacht teaghlaigh","AboutPage.FamilySafetyDescription":"Cruthaigh timpeallacht dhigiteach n\u00EDos s\u00E1bh\u00E1ilte do leana\u00ED agus do dh\u00E9ag\u00F3ir\u00ED, ina bhfuil cosaint\u00ED ceannaigh agus cosaint\u00ED d\u0027fheidhmchl\u00E1ir agus cluich\u00ED aoisoiri\u00FAnacha","AboutPage.TrustedPaymentTitle":"Idirbhearta cosanta","AboutPage.TrustedPaymentDescription":"Coinnigh d\u2019idirbheart sl\u00E1n le beala\u00ED iontaofa nua chun \u00EDoc agus seice\u00E1il amach agus do sh\u00F3cmhainn\u00ED \u00E1 gcosaint agat","AboutPage.ExperienceTitle":"Eisp\u00E9ireas gan str\u00F3 ar Windows","AboutPage.ExperienceDescription":"Suite\u00E1il \u00E9asca agus seice\u00E1il amach go tapa ar ghl\u00E9asanna Microsoft","AboutPage.ConnectedAccount":"D\u0027fheidhmchl\u00E1ir ar do ghl\u00E9asanna uile","AboutPage.ConnectedAccountDescription":"D\u00E9anfar ceannach\u00E1in agus \u00EDosl\u00F3d\u00E1lacha feidhmchl\u00E1ir n\u00F3 cluich\u00ED \u00F3n Store a cheangal le do Chuntas Microsoft, mar sin nuair a fhaigheann t\u00FA t\u00E1irge ar ghl\u00E9as amh\u00E1in, is f\u00E9idir leat \u00E9 a st\u00F3r\u00E1il ar do ghl\u00E9asanna eile gan aon chostas breise.","AboutPage.PlayAnywhere":"Imir \u00E1it ar bith","AboutPage.PlayAnywhereDescription":"Is f\u00E9idir cluich\u00ED a ceanna\u00EDodh \u00F3n Microsoft Store ar do r\u00EDomhaire pearsanta a shuite\u00E1il ar do Xbox gan chostas breise. Agus t\u00E1 a mhalairt f\u00EDor chomh maith: is f\u00E9idir cluich\u00ED \u00E1irithe a ceanna\u00EDodh ar do chons\u00F3l Xbox a shuite\u00E1il ar do r\u00EDomhaire pearsanta.","AboutPage.EfficientUpdates":"Nuashonruithe \u00E9ifeacht\u00FAla","AboutPage.EfficientUpdatesDescription":"Oibr\u00EDonn an Microsoft Store agus Windows le ch\u00E9ile chun a chinnti\u00FA go bhfaigheann feidhmchl\u00E1ir \u00F3n Store nuashonruithe go h\u00E9ifeachtach sa ch\u00FAlra.","AboutPage.DiscoverTitle":"Aimsigh","AboutPage.DiscoverDescription":"F\u00E9ach ar she\u00F3nna \u00F3n bhfeidhmchl\u00E1r sruth\u00FA is fearr leat, d\u00E9an eala\u00EDn dhigiteach le bogearra\u00ED cruthaitheachta n\u00F3 d\u00E9an obair le huirlis\u00ED t\u00E1irgi\u00FAlachta cumhachtacha","AboutPage.Description":"Aimsigh na feidhmchl\u00E1ir is fearr leat. Lig do sc\u00EDth agus scaoil do chuid cruthaitheachta agus t\u00E1irgi\u00FAlachta.","AboutPage.Banner.Title":"Gach rud at\u00E1 uait, san \u00E1it is mian leat \u00E9","AboutPage.Banner.ToStoreAppLabel":"Taisc\u00E9al anois","AboutPage.MicrosoftStoreTitle":"Feidhmchl\u00E1r Microsoft Store","AboutPage.MicrosoftStoreDescription":"Faigh an aip Microsoft Store chun eisp\u00E9ireas n\u00EDos fearr a fh\u00E1il agus t\u00FA ag aimsi\u00FA agus ag nuashonr\u00FA aipeanna agus cluich\u00ED ar Windows.","AboutPage.MicrosoftStoreLogoAlt":"L\u00F3g\u00F3 Microsoft Store","AboutPage.DownloadStoreButton":"\u00CDosl\u00F3d\u00E1il an aip Store","AboutPage.GetStoreAppButton":"Faigh an aip Microsoft Store","AboutPage.NoStoreQuestion":"Nach bhfuil an aip Microsoft Store agat ar do ghl\u00E9as?","AboutPage.DownloadStorePromptLine1":"Mura bhfuil feidhmchl\u00E1r Microsoft Store agat ar do ghl\u00E9as,","AboutPage.DownloadStorePromptLine2":"clice\u00E1il ar {0} chun \u00E9 a \u00EDosl\u00F3d\u00E1il anois.","AboutPage.DownloadStoreLink":"anseo","AboutPage.SeamlessExperience":"ar do ghl\u00E9asanna Windows","AboutPage.TrustedDownload":"\u00CDosl\u00F3d\u00E1lacha Iontaofa","AboutPage.AIIntegrated":"Comhth\u00E1ite le IS","AboutPage.AutomaticUpdates":"Uath-nuashonraigh","AboutPage.TrustedDownloadText":"Sl\u00E1n","AboutPage.AIIntegratedText":"Copilot","AgeVerification.MatureContentSignInRestriction":"S\u00EDnigh isteach chun amharc ar an inneachar seo","AgeVerification.MatureContentSignInSubtitle":"N\u00ED m\u00F3r d\u00FAinn d\u0027aois a fh\u00EDor\u00FA lena chinnti\u00FA go bhfuil an t-inneachar aoisoiri\u00FAnach.","AgeVerification.MatureContentSignInButton":"S\u00EDnigh isteach","AgeVerification.MatureContentUnverifiedRestriction":"F\u00EDoraigh an aois at\u00E1 agat chun amharc ar an inneachar seo","AgeVerification.MatureContentUnverifiedSubtitle":"T\u00E1 f\u00EDor\u00FA aoise ag teast\u00E1il \u00F3 do chuntas sula bhf\u00E9achann t\u00FA ar inneachar faoi shrianadh aoise.","AgeVerification.MatureContentUnverifiedButton":"F\u00EDoraigh","AgeVerification.MatureContentRestriction":"N\u00ED chomhl\u00EDonann do chuntas an riachtanas aoise \u00EDosta chun amharc ar an inneachar seo.","BuyBox.Tooltip.SignInRequired":"N\u00ED m\u00F3r duit s\u00EDni\u00FA isteach chun an feidhmchl\u00E1r seo a fh\u00E1il.","BuyBox.Tooltip.AgeBlocked":"N\u00ED chomhl\u00EDonann do chuntas na riachtanais aoise don t\u00E1irge seo.","BuyBox.Tooltip.VerifyRequired":"N\u00ED m\u00F3r duit an aois at\u00E1 agat a fh\u00EDor\u00FA chun an feidhmchl\u00E1r seo a fh\u00E1il.","AlertService.Retry":"Bain triail eile as","AlertService.SwitchAccount":"Athraigh cuntas","AuthService.SignInError":"Th\u00E1ngamar ar earr\u00E1id. Bain triail eile as.","AuthService.PopupBlockedError":"Cinntigh go bhfuil do bhacaire m\u00EDreanna an\u00EDos d\u00EDchumasaithe ar an su\u00EDomh seo chun s\u00EDni\u00FA isteach.","AuthRedirect.Title":"S\u00EDnithe amach","AuthRedirect.Description":"T\u00E1 t\u00FA s\u00EDnithe amach anois.","BadgePage.AppID.Header":"ID an fheidhmchl\u00E1ir","BadgePage.AppID.Invalid.Tooltip":"Ba cheart 12 charachtar a bheith san ID t\u00E1irge, ach amh\u00E1in m\u00E1 thosa\u00EDonn an ID le XP, agus sa ch\u00E1s sin ba cheart 14 charachtar a bheith ann.","BadgePage.AppID.Tooltip":"ID d\u0027fheidhmchl\u00E1ir. Gheobhaidh t\u00FA \u00E9 seo i L\u00E1rionad Comhph\u00E1irtithe Microsoft, n\u00F3 ag deireadh URL d\u0027fheidhmchl\u00E1ir ar an su\u00EDomh seo, m.sh. https://apps.microsoft.com/detail/9MV0B5HZVK9Z","BadgePage.AutoLaunch.Header":"Uathlainse\u00E1il","BadgePage.AutoLaunch.Tooltip":"M\u00E1 t\u00E1 an M\u00F3d Lainse\u00E1la l\u00E1n agus m\u00E1 t\u00E1 Uathlainse\u00E1il f\u00EDor, oscl\u00F3far an feidhmchl\u00E1r Store go huathoibr\u00EDoch nuair a chlice\u00E1lann t\u00FA ar an suaitheantas.","BadgePage.BadgeText":"\u00CDosl\u00F3d\u00E1il \u00F3 Microsoft Store","BadgePage.ButtonAriaLabel":"{0} Cnaipe","BadgePage.CID.Header":"ID an fheachtais","BadgePage.CID.Tooltip":"C\u00F3d feachtais d\u0027fheidhmchl\u00E1ir. Is f\u00E9idir leat \u00E9 seo a aimsi\u00FA i L\u00E1rionad Comhph\u00E1irtithe Microsoft.","BadgePage.Description":"Is \u00E9 suaitheantas feidhmchl\u00E1ir Microsoft Store an bealach is fearr chun tr\u00E1cht a thaispe\u00E1int, a dh\u00EDri\u00FA, agus a rian\u00FA \u00F3 do sh\u00F3cmhainn\u00ED chuig liost\u00E1il Microsoft Store.","BadgePage.UpdateDescription":"NUASHONR\u00DA: Fillfidh suaitheantais nach bhfuil dromchla lainse\u00E1la socraithe acu go huathoibr\u00EDoch ar an gcine\u00E1l \u2018\u00EDosl\u00F3d\u00E1il dh\u00EDreach\u2019 amach anseo. N\u00ED bheidh an rogha uathlainse\u00E1la ar f\u00E1il le haghaidh \u00EDosl\u00F3d\u00E1lacha d\u00EDreacha. Fillfidh suaitheantais reatha at\u00E1 bunaithe ar JavaScript a d\u0027\u00FAs\u00E1id an cine\u00E1l \u2018m\u00EDr an\u00EDos\u2019 go huathoibr\u00EDoch ar an gcine\u00E1l \u2018\u00EDosl\u00F3d\u00E1il dh\u00EDreach\u2019 chomh maith c\u00E9anna.","BadgePage.UpdatePopupDescription":"Chun lean\u00FAint den Store an\u00EDos a \u00FAs\u00E1id, gin an suaitheantas ar\u00EDs agus bain \u00FAs\u00E1id as an gc\u00F3d nua.","BadgePage.Preview.Tab":"R\u00E9amhamharc","BadgePage.CodeSnippet.Tab":"Blogh c\u00F3id","BadgePage.Optional.Text":"(Roghnach)","BadgePage.Interaction.Header":"Beochan idirghn\u00EDomha\u00EDochta","BadgePage.Interaction.Tooltip":"Beochan an tsuaitheantais ar st\u00E1it ainlithe agus br\u00FAite.","BadgePage.Language.Header":"Teanga","BadgePage.StaticLanguage.Tooltip":"Roghnaigh teanga le go mbeidh an suaitheantas le feice\u00E1il inti.","BadgePage.WebComponentLanguage.Tooltip":"Rindre\u00E1il uathbhraith (molta) an suaitheantas i dteanga bhrabhs\u00E1la\u00ED an \u00FAs\u00E1ideora. Mar mhalairt air sin, roghnaigh teanga chun an suaitheantas a shol\u00E1thar sa teanga sin i gc\u00F3na\u00ED.","BadgePage.Launch.Header":"M\u00F3d lainse\u00E1la","BadgePage.Launch.Tooltip":"M\u00F3d lainse\u00E1la d\u0027fheidhmchl\u00E1ir nuair a chlice\u00E1lann \u00FAs\u00E1ideoir\u00ED ar do shuaitheantas. \u00CDosl\u00F3d\u00E1lann m\u00F3d d\u00EDreach suite\u00E1la\u00ED inrite d\u0027fheidhmchl\u00E1ir agus is \u00E9 sin an r\u00E9amhshocr\u00FA. Oscla\u00EDonn m\u00F3d ioml\u00E1n leathanach t\u00E1irge d\u0027fheidhmchl\u00E1ir ar fheidhmchl\u00E1r Store.","BadgePage.WebComponent.Tab":"Comhph\u00E1irt ghr\u00E9as\u00E1in","BadgePage.TabAriaLabel":"{0} t\u00E1b","BadgePage.TabSelectedAriaLabel":"{0} t\u00E1b roghnaithe","BadgePage.Theme.Header":"T\u00E9ama","BadgePage.StaticTheme.Tooltip":"An t\u00E9ama suaitheantas le h\u00FAs\u00E1id. Is \u00E9 an treoir n\u00E1 c\u00FAlra dorcha a roghn\u00FA ar ch\u00FAlra geal agus a mhalairt.","BadgePage.WebComponentTheme.Tooltip":"Aimseoidh Uathaimsigh t\u00E9ama an \u00FAs\u00E1ideora agus taispe\u00E1nfar an t\u00E9ama suaitheantais comhfhreagrach.","BadgePage.Title":"T\u00F3g do shuaitheantas feidhmchl\u00E1ir","BadgePage.Tooltip":"leid uirlise.","BadgePage.Guidelines.Tooltip":"Treoirl\u00EDnte","BadgePage.False.Option":"Br\u00E9agach","BadgePage.True.Option":"F\u00EDor","BadgePage.Direct.Option":"D\u00EDreach","BadgePage.Full.Option":"L\u00E1n","BadgePage.None.Option":"Dada","BadgePage.Dark.Option":"Dorcha","BadgePage.Light.Option":"Geal","BadgePage.Off.Option":"Casta as","BadgePage.On.Option":"Casta air","BadgePage.AutoDetect.Option":"Uathaimsigh","BadgePage.GenerateBadge":"Gin suaitheantas","BadgePage.CopiedClipboard":"C\u00F3ipe\u00E1ilte chuig an ngearrthaisce!","BadgePage.StaticBadge.Title":"Suaitheantas statach","BadgePage.StaticBadge.SimpleDescription":"Suaitheantas simpl\u00ED \u00E9adrom a \u00FAs\u00E1ideann \u00EDomh\u00E1 agus nasc caighde\u00E1nach.","BadgePage.StaticBadge.Description":"T\u00E1 an suaitheantas seo oiri\u00FAnach do READMEanna, su\u00EDomhanna doicim\u00E9adachta, timpeallachta\u00ED le Polasaithe Sl\u00E1nd\u00E1la \u00C1bhair, n\u00F3 \u00E1it ar bith a bhfuil srian ar scripteanna seachtracha.\u00A0","BadgePage.WebComponentBadge.Title":"Suaitheantas comhph\u00E1irte gr\u00E9as\u00E1in","BadgePage.WebComponentBadge.SimpleDescription":"Suaitheantas dinimici\u00FAil agus idirghn\u00EDomhach at\u00E1 t\u00F3gtha mar chomhph\u00E1irt ghr\u00E9as\u00E1in.","BadgePage.WebComponentBadge.Description":"T\u00E1 an suaitheantas seo bunaithe ar JavaScript agus tairgeann s\u00E9 gn\u00E9ithe nua-aimseartha lena n-\u00E1ir\u00EDtear uathaimsi\u00FA logchaighde\u00E1in agus t\u00E9ama chomh maith le beochan m\u00EDn ainlithe. Roghnaigh an rogha seo nuair is mian leat an t-eisp\u00E9ireas is saincheaptha is fearr a fh\u00E1il do d\u0027\u00FAs\u00E1ideoir\u00ED.","BadgePage.GetStarted.Title":"Tosaigh","BadgePage.GetStarted.Description":"Lean na c\u00E9imeanna seo chun do shuaitheantas a ghini\u00FAint agus \u00E9 a chur le do shu\u00EDomh Gr\u00E9as\u00E1in.","BadgePage.GetStarted.Step1.Title":"Roghnaigh cine\u00E1l suaitheantais","BadgePage.GetStarted.Step1.Description":"Roghnaigh idir comhph\u00E1irt Ghr\u00E9as\u00E1in n\u00F3 suaitheantas statach. Mura bhfuil t\u00FA cinnte, is seans s\u00E1bh\u00E1ilte \u00E9 an suaitheantas statach.","BadgePage.GetStarted.Step2.Title":"Iontr\u00E1il d\u2019Aitheantas Feidhmchl\u00E1ir","BadgePage.GetStarted.Step2.Description":"Greamaigh d\u0027ID feidhmchl\u00E1ir 12 charachtar (a aims\u00EDodh i do phain\u00E9al L\u00E1rionad Comhph\u00E1irtithe) isteach sa bhosca t\u00E9acs.","BadgePage.GetStarted.Step3.Title":"Roghnaigh air\u00EDonna","BadgePage.GetStarted.Step3.Description":"Saincheap an teanga, an t\u00E9ama, agus na spriocanna seolta, n\u00F3 cuir aitheantas feachtais leis chun an fheidhm\u00EDocht a rian\u00FA.","BadgePage.GetStarted.Step4.Title":"C\u00F3ipe\u00E1il an c\u00F3d","BadgePage.GetStarted.Step4.Description":"Clice\u00E1il \u0022Gin do shuaitheantas\u0022 agus greamaigh an bl\u00FAir\u00EDn go d\u00EDreach isteach i gc\u00F3d do shu\u00EDmh ghr\u00E9as\u00E1in.","BadgePage.Guidelines.Title":"Treoirl\u00EDnte agus dea-chleachtais","BadgePage.Guidelines.Description":"Lean na dea-chleachtais seo chun do r\u00E1ta\u00ED comhsh\u00F3 a uasmh\u00E9ad\u00FA agus comhsheasmhacht branda a choinne\u00E1il.","BadgePage.Guidelines.KeepItClear.Title":"Coinnigh soil\u00E9ir \u00E9","BadgePage.Guidelines.KeepItClear.Description":"Coinnigh sp\u00E1s\u00E1il chaighde\u00E1nach timpeall an tsuaitheantais. N\u00E1 cuir t\u00E9acs n\u00E1 grafaic\u00ED eile leis an iomarca.","BadgePage.Guidelines.PlaceProminent.Title":"Cuir in \u00E1it fheici\u00FAil \u00E9","BadgePage.Guidelines.PlaceProminent.Description":"Cuir an suaitheantas \u0022os cionn an fhillte\u0022 ar do leathanach baile, n\u00F3 d\u00EDreach in aice le liosta pr\u00EDomhghn\u00E9ithe d\u0027fheidhmchl\u00E1ir chun na r\u00E1ta\u00ED is fearr a fh\u00E1il.","BadgePage.Guidelines.DontAlter.Title":"N\u00E1 hathraigh an t-eala\u00EDn","BadgePage.Guidelines.DontAlter.Description":"\u00DAs\u00E1id an c\u00F3d a ghintear go d\u00EDreach. N\u00E1 s\u00EDn, n\u00E1 hathdhathaigh n\u00E1 n\u00E1 modhnaigh grafaic\u00ED an tsuaitheantais, mar go s\u00E1ra\u00EDonn s\u00E9 seo treoirl\u00EDnte branda Microsoft Store.","BadgePage.Guidelines.CampaignId.Title":"Cuir aitheantas feachtais leis chun feidhm\u00EDocht a rian\u00FA","BadgePage.Guidelines.CampaignId.Description":"M\u00E1 chuirtear aitheantas feachtais leis, is f\u00E9idir leat cuairteoir\u00ED agus tiontuithe a rian\u00FA, rud a \u00E9asca\u00EDonn triail a bhaint as su\u00EDomhanna \u00E9ags\u00FAla. I ndeireadh na d\u00E1la, n\u00ED f\u00E9idir leat feabhas a chur ar rud nach dtomhaiseann t\u00FA!","BadgePage.Guidelines.DownloadLink":"\u00CDosl\u00F3d\u00E1il na treoirl\u00EDnte ioml\u00E1na (PDF)","BadgePage.FAQ.Title":"FAQ","BadgePage.FAQ.FindAppId.Question":"C\u00E1 h\u00E1it ar f\u00E9idir liom m\u0027ID feidhmchl\u00E1ir 12 charachtar (aitheantas t\u00E1irge) a aimsi\u00FA?","BadgePage.FAQ.FindAppId.Answer1":"Is c\u00F3d alfa-uimhri\u00FAil uath\u00FAil 12 charachtar \u00E9 \u00E1r n-Aitheantas Feidhmchl\u00E1ir (ar a dtugtar an tAitheantas T\u00E1irge freisin) a shanntar do d\u0027fheidhmchl\u00E1r. Is f\u00E9idir leat \u00E9 a fh\u00E1il i do phain\u00E9al L\u00E1rionad Comhph\u00E1irtithe Windows. T\u00E9igh chuig leathanach d\u0027fheidhmchl\u00E1ir, roghnaigh Bainist\u00EDocht feidhmchl\u00E1r \u003E Aitheantas feidhmchl\u00E1ir agus cuardaigh an luach \u0022Aitheantas Store\u0022.","BadgePage.FAQ.FindAppId.Answer2":"Mar mhalairt air sin, is f\u00E9idir leat d\u0027fheidhmchl\u00E1r a fh\u00E1il ar apps.microsoft.com. Is \u00E9 d\u2019aitheantas Feidhmchl\u00E1ir an c\u00F3d 12 charachtar ag deireadh an URL: apps.microsoft.com/detail/\u003CAppID\u003E.","BadgePage.FAQ.TrackDownloads.Question":"Conas is f\u00E9idir liom a rian\u00FA c\u00E9 mh\u00E9ad \u00EDosl\u00F3d\u00E1il a ghintear \u00F3 mo shu\u00EDomh gr\u00E9as\u00E1in?","BadgePage.FAQ.TrackDownloads.Answer":"Is f\u00E9idir leat feidhm\u00EDocht suaitheantais a rian\u00FA tr\u00ED Aitheantas Feachtais (cid) a chur le do nasc suaitheantais. Agus do shuaitheantas \u00E1 ghini\u00FAint thuas, cuir isteach ainm feachtais saincheaptha (m.sh., \u0022fooapp_website\u0022). Ansin is f\u00E9idir leat na r\u00E1ta\u00ED clice\u00E1il agus na sonra\u00ED comhsh\u00F3 a bhaineann leis an bhfeachtas sonrach sin a fheice\u00E1il i do Thuarasc\u00E1il \u00C9ad\u00E1la L\u00E1rionad Comhph\u00E1irtithe.","BadgePage.FAQ.WhichBadgeType.Question":"C\u00E9n cine\u00E1l suaitheantais ba ch\u00F3ir dom a roghn\u00FA: Comhph\u00E1irt Statach n\u00F3 Gr\u00E9as\u00E1in?","BadgePage.FAQ.WhichBadgeType.Answer1":"Roghnaigh an Comhph\u00E1irt Gr\u00E9as\u00E1in don eisp\u00E9ireas \u00FAs\u00E1ideora is fearr ar shu\u00EDomhanna gr\u00E9as\u00E1in nua-aimseartha. Braitheann s\u00E9 teanga ch\u00F3rais an \u00FAs\u00E1ideora go huathoibr\u00EDoch, d\u00E9anann s\u00E9 nuashonruithe chun meaitse\u00E1il le teanga dearaidh reatha Microsoft agus sol\u00E1thra\u00EDonn s\u00E9 beochana luiche r\u00E9idh.","BadgePage.FAQ.WhichBadgeType.Answer2":"Roghnaigh an suaitheantas statach m\u00E1 chuireann d\u0027ard\u00E1n srian ar JavaScript (amhail GitHub READMEs, WordPress gan JS saincheaptha, n\u00F3 timpeallachta\u00ED dochair polasa\u00ED sl\u00E1nd\u00E1la inneachair).","BadgePage.FAQ.UpdateBadge.Question":"An bhfuil orm mo shuaitheantas a nuashonr\u00FA m\u00E1 athra\u00EDonn branda Microsoft Store?","BadgePage.FAQ.UpdateBadge.Answer":"M\u00E1 t\u00E1 na suaitheantais a gineadh \u00F3n leathanach seo in \u00FAs\u00E1id agat, n\u00EDl. T\u00E1 na s\u00F3cmhainn\u00ED \u00E1 n-\u00F3st\u00E1il ag Microsoft agus nuashonr\u00F3far do shuaitheantas go huathoibr\u00EDoch chun athbhrand\u00E1il n\u00F3 athruithe deartha amach anseo a l\u00E9iri\u00FA.","BadgePage.FAQ.ResizeBadge.Question":"An f\u00E9idir liom m\u00E9id an tsuaitheantais a athr\u00FA chun oiri\u00FAn\u00FA do dhearadh mo shu\u00EDmh ghr\u00E9as\u00E1in?","BadgePage.FAQ.ResizeBadge.Answer":"T\u00E1 suaitheantas na comhph\u00E1irte Gr\u00E9as\u00E1in freagr\u00FAil go n\u00E1d\u00FArtha agus d\u00E9anfar \u00E9 a sc\u00E1l\u00FA i gceart. M\u00E1 t\u00E1 an \u00EDomh\u00E1 statach in \u00FAs\u00E1id agat, is f\u00E9idir leat CSS a \u00FAs\u00E1id chun an \u00EDomh\u00E1 a sc\u00E1l\u00FA (m.sh., an t-uasleithead a choigeart\u00FA), ach n\u00ED m\u00F3r duit an c\u00F3imheas treo\u00EDochta bunaidh a chaomhn\u00FA. N\u00E1 s\u00EDn, cuir ar sceabha, n\u00E1 bearr an \u00EDomh\u00E1 riamh.","BadgePage.FAQ.DarkMode.Question":"An dtaca\u00EDonn an suaitheantas leis an m\u00F3d dorcha?","BadgePage.FAQ.DarkMode.Answer":"Cinnte. Is f\u00E9idir leis an suaitheantas Comhph\u00E1irt Gr\u00E9as\u00E1in t\u00E9ama c\u00F3rais an \u00FAs\u00E1ideora n\u00F3 t\u00E9ama CSS do shu\u00EDomh gr\u00E9as\u00E1in a aithint go huathoibr\u00EDoch agus leagan dorcha n\u00F3 geal a thaispe\u00E1int. Lena chois sin, is f\u00E9idir leat \u00E9 a chur i bhfeidhm chun taispe\u00E1int i m\u00F3d dorcha n\u00F3 geal i gc\u00F3na\u00ED ag \u00FAs\u00E1id na huirlis\u00ED ginead\u00F3ra thuas.","BadgePage.SideNav.GetStarted":"Tosaigh","BadgePage.SideNav.BuildYourBadge":"T\u00F3g do shuaitheantas","BadgePage.SideNav.StaticBadge":"Suaitheantas statach","BadgePage.SideNav.WebComponentBadge":"Suaitheantas comhph\u00E1irte gr\u00E9as\u00E1in","BadgePage.SideNav.Guidelines":"Treoirl\u00EDnte","BadgePage.SideNav.FAQ":"FAQ","Common.CollectionsTitle":"Baili\u00FAch\u00E1in","CollectionReel.PlayButton":"Seinn an bheochan ar an r\u00EDl baili\u00FAch\u00E1in","CollectionReel.PauseButton":"Cur an bheochan ar sos ar an r\u00EDl baili\u00FAch\u00E1in","Common.PageTitle":"{0} - Feidhmchl\u00E1ir Microsoft","Common.PageAppsTitle":"{0} - \u00CDosl\u00F3d\u00E1il agus suite\u00E1il ar Windows | Microsoft Store","Common.PageAppsFreeTitle":"{0} - \u00CDosl\u00F3d\u00E1il saor in aisce agus suite\u00E1il ar Windows | Microsoft Store","Common.PageGameTitle":"{0} - \u00CDosl\u00F3d\u00E1il agus imir ar Windows | Microsoft Store","Common.PageGameFreeTitle":"{0} - \u00CDosl\u00F3d\u00E1il agus imir gan chostas ar Windows | Microsoft Store","MsStoreDetails.PageTitle":"\u00CDosl\u00F3d\u00E1il agus suite\u00E1il an feidhmchl\u00E1r Microsoft Store ar Windows","Common.ScrollLeft.ButtonTitle":"Scrollaigh ar chl\u00E9","Common.ScrollRight.ButtonTitle":"Scrollaigh ar dheis","Common.ScrollToTop.ButtonTitle":"Scrollaigh chuig an tasc","Common.SeeAll":"F\u00E9ach gach ceann","Common.SeeAllTitle":"F\u00E9ach ar gach {0}. \u00DAs\u00E1id na saigheadeochracha chun brabhs\u00E1il tr\u00ED na m\u00EDreanna","Collection.LoadMore":"Tuilleadh a thaispe\u00E1int","Common.SeeDetails":"F\u00E9ach sonra\u00ED","Common.AdBadge":"F\u00F3gra","Common.MenuItemSelected":"{0} roghnaithe","Common.SpotlightCard":"{0}, {1} as {2}","Common.SpotlightDotButton":"Sleamhn\u00E1n {0}: {1}","Common.SpotlightDotButtonSelected":"Sleamhn\u00E1n: {0}: {1}, roghnaithe","Common.ProductCardPosition":"{0}, {1} as {2}","Common.Description":"Cur s\u00EDos","Common.Ellipsis":"{0}...","Common.LearnMore":"Faigh tuilleadh eolais","Common.App":"feidhmchl\u00E1r","Common.SpecialOffers":"Tairiscint\u00ED speisialta sealadacha","Common.UnableToConnect":"N\u00ED f\u00E9idir ceangal","Common.UnableToConnectDetails":"Bh\u00ED fadhb leis na sonra\u00ED a l\u00F3d\u00E1il. B\u2019fh\u00E9idir go mbeadh s\u00E9 cabhrach an leathanach a athnuachan.","Common.ExploreNow":"Taisc\u00E9al anois","Common.DownloadErrorTip":"Tharla earr\u00E1id gan choinne, bain triail eile as ar ball","Common.Trending":"Treocht\u00FA","ContactInfo.Address":"Seoladh","ContactInfo.Email":"R\u00EDomhphost","ContactInfo.Name":"Ainm","Collections.CollectionPosition":"Baili\u00FAch\u00E1n {0} as {1}","Footer.ColumnHeaderWhatsNew":"Forbairt\u00ED is d\u00E9ana\u00ED","Footer.ColumnWhatsNewLinkMoreContent":"Tuilleadh inneachair sa Microsoft Store","Footer.ColumnWhatsNewLinkApps":"Feidhmchl\u00E1ir","Footer.ColumnWhatsNewLinkGames":"Cluich\u00ED","Footer.ColumnWhatsNewLinkThemes":"T\u00E9ama\u00ED","Footer.ColumnWhatsNewLinkWinExpBlog":"Blag Eisp\u00E9iris Windows","Footer.ColumnHeaderMSStore":"Microsoft Store","Footer.ColumnMSStoreLinkAccountProfile":"Cuntas Microsoft","Footer.ColumnMSStoreLinkSupport":"Taca\u00EDocht Microsoft Store","Footer.ColumnMSStoreLinkAccountReturns":"Ais\u00EDoca\u00EDochta\u00ED","Footer.ColumnMSStoreLinkFlexPay":"\u00CDoca\u00EDochta\u00ED sol\u00FAbtha","Footer.ColumnMSStoreLinkAccountStorePolicy":"Polasaithe agus C\u00F3d Iompair","Footer.ColumnMSStoreLinkGetStoreApp":"Faigh an aip Microsoft Store","Footer.ColumnHeaderForDevelopers":"Le haghaidh forbr\u00F3ir\u00ED","Footer.ColumnForDevsLinkPublishApp":"Foilsigh d\u0027aip","Footer.ColumnForDevsLinkAdvWithUs":"D\u00E9an f\u00F3gra\u00EDocht linn","Footer.ColumnForDevsLinkGenBadge":"Gin do shuaitheantas feidhmchl\u00E1ir","Footer.ColumnHeaderWindows":"Windows","Footer.ColumnWindowsLinkCareers":"Gairmeacha","Footer.ColumnWindowsLinkAbout":"Maidir le Microsoft","Footer.ColumnWindowsLinkNews":"Sc\u00E9alta na cuideachta","Footer.ColumnWindowsLinkInvest":"Infheisteoir\u00ED","Footer.ColumnWindowsLinkDI":"\u00C9ags\u00FAlacht \u0026 Cu