        window.pageLocalizer = {"hl":"cs-CZ","gl":"CZ","uiLocale":"cs-CZ","marketDetails":{"market":"CZ","tier":2},"isEmbargoedMarket":false,"localeStrings":{"AboutPage.DisclaimerPlus":"Obrazovky jsou simulovan\u00E9. Funkce a dostupnost aplikac\u00ED se m\u016F\u017Eou v jednotliv\u00FDch oblastech li\u0161it. Aplikace, hry a dal\u0161\u00ED obsah nebo p\u0159edplatn\u00E1 se prod\u00E1vaj\u00ED samostatn\u011B; bezplatn\u00E9 aplikace m\u016F\u017Eou obsahovat reklamy nebo n\u00E1kupy v aplikaci.","AboutPage.DisclaimerOne":"Plat\u00ED jenom pro vybran\u00E9 oblasti.","AboutPage.DisclaimerTwo":"Aplikace ve Storu, kter\u00E9 distribuuje p\u0159\u00EDslu\u0161n\u00FD v\u00FDvoj\u00E1\u0159, jsou dan\u00FDm v\u00FDvoj\u00E1\u0159em aktualizov\u00E1ny samostatn\u011B.","AboutPage.DisclaimerThree":"Zabezpe\u010Den\u00E9 zp\u016Fsoby platby z\u00E1vis\u00ED na vybran\u00E9m obsahu a aplikac\u00EDch.","AboutPage.SocialApps":"APLIKACE SOCI\u00C1LN\u00CDCH S\u00CDT\u00CD","AboutPage.SocialAppsSubtitle":"P\u0159ipojte se a u\u010Dte se","AboutPage.ProductivityApps":"KANCEL\u00C1\u0158SK\u00C9 APLIKACE","AboutPage.ProductivityAppsSubtitle":"Dos\u00E1hn\u011Bte v\u00EDce odkudkoli","AboutPage.ClassicGames":"KLASICK\u00C9 HRY","AboutPage.ClassicGamesSubtitle":"Klasika, kter\u00E1 nikdy nezest\u00E1rne","AboutPage.ExploreMore":"Prozkoumat v\u00EDce","AboutPage.ExploreNow":"Prozkoumat hned","AboutPage.ImageAlt":"Obr\u00E1zek pozad\u00ED informa\u010Dn\u00EDho banneru.","AboutPage.Title":"Aplikace a hry pro pr\u00E1ci a z\u00E1bavu","AboutPage.MetaTitle":"Objevujte a prozkoumejte aplikace a hry na Microsoft Store","AboutPage.MetaDescription":"Prozkoumejte rozs\u00E1hl\u00FD v\u00FDb\u011Br zabezpe\u010Den\u00FDch aplikac\u00ED a her na Microsoft Store. Zjist\u011Bte, pro\u010D je to nejlep\u0161\u00ED m\u00EDsto pro bezpe\u010Dn\u00E9 a spolehliv\u00E9 stahov\u00E1n\u00ED. Objevte v\u00EDce je\u0161t\u011B dnes!","AboutPage.Number":"P\u0159ej\u00EDt na doln\u00ED index {0}","AboutPage.GamingTitle":"Hran\u00ED na stoln\u00EDm po\u010D\u00EDta\u010Di","AboutPage.GamingDescription":"Hrajte po\u010D\u00EDta\u010Dov\u00E9 hry od oce\u0148ovan\u00FDch nez\u00E1visl\u00FDch v\u00FDvoj\u00E1\u0159\u016F her i vydavatel\u016F AAA","AboutPage.ExploreGames":"Prozkoumat hry","AboutPage.ExploreApps":"Prozkoumat aplikace","AboutPage.RewardsTitle":"Rewards","AboutPage.RewardsDescription":"P\u0159i n\u00E1kupu produkt\u016F ze Storu v zapojen\u00FDch oblastech z\u00EDsk\u00E1te body Microsoft Rewards. Body m\u016F\u017Eete vym\u011Bnit za d\u00E1rkov\u00E9 karty, dary nebo \u00FA\u010Dast ve slosov\u00E1n\u00ED.","AboutPage.AiHub":"Centrum AI","AboutPage.AiHubDescription":"Nov\u00E9 m\u00EDsto, kde z\u00EDsk\u00E1te vysoce kvalitn\u00ED aplikace s um\u011Blou inteligenc\u00ED, kter\u00E9 zv\u00FD\u0161\u00ED va\u0161i produktivitu a kreativitu.","AboutPage.TrustworthyTitle":"D\u016Fv\u011Bryhodn\u00E9 a zabezpe\u010Den\u00E9","AboutPage.TrustworthyDescription":"Stahujte bezpe\u010Dn\u011B ov\u011B\u0159en\u00E9 aplikace a d\u016Fv\u011B\u0159ujte tomu, co instalujete.","AboutPage.CertificationTitle":"Striktn\u00ED proces ov\u011B\u0159en\u00ED","AboutPage.CertificationDescription":"V\u0161echny aplikace jsou kontrolov\u00E1ny na p\u0159\u00EDtomnost zn\u00E1m\u00E9ho malwaru a bezpe\u010Dnostn\u00EDch probl\u00E9m\u016F. P\u0159ed z\u00EDsk\u00E1n\u00EDm aplikace tak\u00E9 kontrolujeme kompatibilitu.","AboutPage.FamilySafetyTitle":"Zabezpe\u010Den\u00ED rodiny","AboutPage.FamilySafetyDescription":"Vytvo\u0159te bezpe\u010Dn\u011Bj\u0161\u00ED digit\u00E1ln\u00ED prost\u0159ed\u00ED pro d\u011Bti a dosp\u00EDvaj\u00EDc\u00ED s ochranou p\u0159ed n\u00E1kupem a ochranou aplikac\u00ED a her odpov\u00EDdaj\u00EDc\u00EDch v\u011Bku.","AboutPage.TrustedPaymentTitle":"Zabezpe\u010Den\u00E9 transakce","AboutPage.TrustedPaymentDescription":"Zabezpe\u010Dte svou transakci d\u016Fv\u011Bryhodn\u00FDmi zp\u016Fsoby platby a p\u0159i placen\u00ED chra\u0148te to, co je va\u0161e.","AboutPage.ExperienceTitle":"Hladk\u00E9 fungov\u00E1n\u00ED ve Windows","AboutPage.ExperienceDescription":"Snadn\u00E1 instalace a rychl\u00E1 kontrola nap\u0159\u00ED\u010D za\u0159\u00EDzen\u00EDmi Microsoftu","AboutPage.ConnectedAccount":"Va\u0161e aplikace na v\u0161ech va\u0161ich za\u0159\u00EDzen\u00EDch","AboutPage.ConnectedAccountDescription":"N\u00E1kupy a sta\u017Een\u00ED aplikac\u00ED nebo her ze Storu se p\u0159ipoj\u00ED k va\u0161emu \u00FA\u010Dtu Microsoft, tak\u017Ee kdy\u017E si produkt po\u0159\u00EDd\u00EDte na jednom za\u0159\u00EDzen\u00ED, m\u016F\u017Eete ho bez dal\u0161\u00EDch poplatk\u016F obnovit na jin\u00E1 za\u0159\u00EDzen\u00ED.","AboutPage.PlayAnywhere":"Play Anywhere","AboutPage.PlayAnywhereDescription":"Z\u00FA\u010Dastn\u011Bn\u00E9 hry zakoupen\u00E9 v obchod\u011B Microsoft Store na po\u010D\u00EDta\u010Di lze bez dal\u0161\u00EDch n\u00E1klad\u016F nainstalovat na konzoli Xbox. A plat\u00ED to i obr\u00E1cen\u011B: hry zakoupen\u00E9 na konzoli Xbox lze nainstalovat do po\u010D\u00EDta\u010De.","AboutPage.EfficientUpdates":"Efektivn\u00ED aktualizace","AboutPage.EfficientUpdatesDescription":"Microsoft Store a Windows spolupracuj\u00ED, aby aplikace ze Storu plynule dost\u00E1valy aktualizace na pozad\u00ED.","AboutPage.DiscoverTitle":"Vyhledat","AboutPage.DiscoverDescription":"Sledujte po\u0159ady z va\u0161\u00ED obl\u00EDben\u00E9 streamovac\u00ED aplikace, tvo\u0159te digit\u00E1ln\u00ED um\u011Bn\u00ED pomoc\u00ED kreativn\u00EDho softwaru nebo pracujte s v\u00FDkonn\u00FDmi n\u00E1stroji pro zv\u00FD\u0161en\u00ED produktivity","AboutPage.Description":"Najd\u011Bte si sv\u00E9 obl\u00EDben\u00E9 aplikace. Odpo\u010Di\u0148te si a popus\u0165te uzdu sv\u00E9 kreativit\u011B a produktivit\u011B.","AboutPage.Banner.Title":"V\u0161echno, co chcete, p\u0159esn\u011B tam, kde to chcete","AboutPage.Banner.ToStoreAppLabel":"Prozkoumat hned","AboutPage.MicrosoftStoreTitle":"Aplikace z obchodu Microsoft Store","AboutPage.MicrosoftStoreDescription":"Nainstalujte si aplikaci Microsoft Store, kter\u00E1 v\u00E1m zajist\u00ED lep\u0161\u00ED prost\u0159ed\u00ED pro hled\u00E1n\u00ED a aktualizaci aplikac\u00ED a her ve Windows.","AboutPage.MicrosoftStoreLogoAlt":"Logo Microsoft Store","AboutPage.DownloadStoreButton":"St\u00E1hnout aplikaci Store","AboutPage.GetStoreAppButton":"Z\u00EDskat aplikaci Microsoft Store","AboutPage.NoStoreQuestion":"Nem\u00E1te na sv\u00E9m za\u0159\u00EDzen\u00ED aplikaci Microsoft Store?","AboutPage.DownloadStorePromptLine1":"Pokud na za\u0159\u00EDzen\u00ED nem\u00E1te aplikaci Microsoft Store,","AboutPage.DownloadStorePromptLine2":"kliknut\u00EDm {0} si ji st\u00E1hn\u011Bte.","AboutPage.DownloadStoreLink":"sem","AboutPage.SeamlessExperience":"na za\u0159\u00EDzen\u00EDch s Windows","AboutPage.TrustedDownload":"D\u016Fv\u011Bryhodn\u00E9 soubory ke sta\u017Een\u00ED","AboutPage.AIIntegrated":"Integrovan\u00E1 um\u011Bl\u00E1 inteligence","AboutPage.AutomaticUpdates":"Automatick\u00E1 aktualizace","AboutPage.TrustedDownloadText":"Zabezpe\u010Den\u00E9","AboutPage.AIIntegratedText":"Copilot","AgeVerification.MatureContentSignInRestriction":"P\u0159ihlaste se, abyste si mohli zobrazit tento obsah","AgeVerification.MatureContentSignInSubtitle":"Pot\u0159ebujeme ov\u011B\u0159it v\u00E1\u0161 v\u011Bk, abychom zajistili, \u017Ee je tento obsah v\u011Bkov\u011B odpov\u00EDdaj\u00EDc\u00ED.","AgeVerification.MatureContentSignInButton":"P\u0159ihl\u00E1sit se","AgeVerification.MatureContentUnverifiedRestriction":"Ov\u011B\u0159te sv\u016Fj v\u011Bk, abyste si mohli tento obsah prohl\u00E9dnout","AgeVerification.MatureContentUnverifiedSubtitle":"P\u0159ed zobrazen\u00EDm obsahu s v\u011Bkov\u00FDm omezen\u00EDm je nutn\u00E9 ov\u011B\u0159it v\u00E1\u0161 v\u011Bk.","AgeVerification.MatureContentUnverifiedButton":"Ov\u011B\u0159it","AgeVerification.MatureContentRestriction":"V\u00E1\u0161 \u00FA\u010Det nespl\u0148uje po\u017Eadavek na minim\u00E1ln\u00ED v\u011Bk pro zobrazen\u00ED tohoto obsahu.","BuyBox.Tooltip.SignInRequired":"Pokud chcete tuto aplikaci st\u00E1hnout, mus\u00EDte se p\u0159ihl\u00E1sit.","BuyBox.Tooltip.AgeBlocked":"V\u00E1\u0161 \u00FA\u010Det nespl\u0148uje po\u017Eadavky na v\u011Bk pro tento produkt.","BuyBox.Tooltip.VerifyRequired":"Abyste si mohli tuto aplikaci st\u00E1hnout, mus\u00EDte potvrdit sv\u016Fj v\u011Bk.","AlertService.Retry":"Zkusit znovu","AlertService.SwitchAccount":"P\u0159epnout \u00FA\u010Det","AuthService.SignInError":"Do\u0161lo k chyb\u011B. Zkuste to znovu.","AuthService.PopupBlockedError":"Ujist\u011Bte se, \u017Ee je na t\u00E9to str\u00E1nce vypnuto blokov\u00E1n\u00ED vyskakovac\u00EDch oken, abyste se mohli p\u0159ihl\u00E1sit.","AuthRedirect.Title":"Odhl\u00E1\u0161eno","AuthRedirect.Description":"Te\u010F jste odhl\u00E1\u0161eni.","BadgePage.AppID.Header":"ID aplikace","BadgePage.AppID.Invalid.Tooltip":"ID produktu by m\u011Blo m\u00EDt 12 znak\u016F, pokud ID neza\u010D\u00EDn\u00E1 na XP. V takov\u00E9m p\u0159\u00EDpad\u011B by m\u011Blo m\u00EDt 14 znak\u016F.","BadgePage.AppID.Tooltip":"ID va\u0161\u00ED aplikace. Najdete ho v Partnersk\u00E9m centru spole\u010Dnosti Microsoft, nebo na konci adresy URL va\u0161\u00ED aplikace na tomto webu, nap\u0159. https://apps.microsoft.com/detail/9MV0B5HZVK9Z","BadgePage.AutoLaunch.Header":"Automatick\u00E9 spu\u0161t\u011Bn\u00ED","BadgePage.AutoLaunch.Tooltip":"Pokud je re\u017Eim spu\u0161t\u011Bn\u00ED \u00FApln\u00FD a automatick\u00E9 spu\u0161t\u011Bn\u00ED je pravdiv\u00E9, kliknut\u00EDm na odzn\u00E1\u010Dek se automaticky otev\u0159e aplikace Store.","BadgePage.BadgeText":"St\u00E1hn\u011Bte si z obchodu Microsoft Store","BadgePage.ButtonAriaLabel":"Tla\u010D\u00EDtko {0}","BadgePage.CID.Header":"ID kampan\u011B","BadgePage.CID.Tooltip":"K\u00F3d kampan\u011B va\u0161\u00ED aplikace. Najdete ho v partnersk\u00E9m centru Microsoft.","BadgePage.Description":"Odzn\u00E1\u010Dek aplikace Microsoft Store je nejlep\u0161\u00ED zp\u016Fsob, jak zobrazovat, sm\u011Brovat a sledovat p\u0159enosy z va\u0161ich prost\u0159edk\u016F do popisu ve Storu.","BadgePage.UpdateDescription":"AKTUALIZACE: Odzn\u00E1\u010Dky, kter\u00E9 nemaj\u00ED nastavenou spou\u0161t\u011Bc\u00ED plochu, budou nyn\u00ED ve v\u00FDchoz\u00EDm nastaven\u00ED nastaveny na typ p\u0159\u00EDm\u00E9ho sta\u017Een\u00ED. Mo\u017Enost automatick\u00E9ho spu\u0161t\u011Bn\u00ED nebude k dispozici pro p\u0159\u00EDm\u00E9 stahov\u00E1n\u00ED. St\u00E1vaj\u00EDc\u00ED odzn\u00E1\u010Dky zalo\u017Een\u00E9 na JavaScriptu, kter\u00E9 pou\u017E\u00EDvaly typ \u201Eautomaticky otev\u00EDran\u00E9 okno\u201C, budou tak\u00E9 ve v\u00FDchoz\u00EDm nastaven\u00ED nastaveny na typ p\u0159\u00EDm\u00E9ho sta\u017Een\u00ED.","BadgePage.UpdatePopupDescription":"Pokud chcete d\u00E1l pou\u017E\u00EDvat m\u00EDstn\u00ED nab\u00EDdku Store, vygenerujte pros\u00EDm odzn\u00E1\u010Dek znovu a pou\u017Eijte nov\u00FD k\u00F3d.","BadgePage.Preview.Tab":"Preview","BadgePage.CodeSnippet.Tab":"Fragment k\u00F3du","BadgePage.Optional.Text":"(Voliteln\u00E9)","BadgePage.Interaction.Header":"Animace interakce","BadgePage.Interaction.Tooltip":"Animace odzn\u00E1\u010Dku p\u0159i stavu najet\u00ED my\u0161\u00ED a zm\u00E1\u010Dknut\u00ED.","BadgePage.Language.Header":"Jazyk","BadgePage.StaticLanguage.Tooltip":"Zvolte jazyk, ve kter\u00E9m se m\u00E1 odzn\u00E1\u010Dek vykreslit.","BadgePage.WebComponentLanguage.Tooltip":"Automatick\u00E9 rozpozn\u00E1n\u00ED (doporu\u010Deno) vykresl\u00ED odzn\u00E1\u010Dek v jazyce prohl\u00ED\u017Ee\u010De u\u017Eivatele. M\u016F\u017Eete tak\u00E9 zvolit jazyk, ve kter\u00E9mu se m\u00E1 odzn\u00E1\u010Dek v\u017Edy vykreslit v dan\u00E9m jazyce.","BadgePage.Launch.Header":"Re\u017Eim spu\u0161t\u011Bn\u00ED","BadgePage.Launch.Tooltip":"Re\u017Eim spu\u0161t\u011Bn\u00ED va\u0161\u00ED aplikace, kdy\u017E u\u017Eivatel\u00E9 kliknou na v\u00E1\u0161 odzn\u00E1\u010Dek. P\u0159\u00EDm\u00FD re\u017Eim st\u00E1hne spustiteln\u00FD soubor instala\u010Dn\u00EDho programu va\u0161\u00ED aplikace a je v\u00FDchoz\u00ED. \u00DApln\u00FD re\u017Eim otev\u0159e str\u00E1nku produktu va\u0161\u00ED aplikace v aplikaci Store.","BadgePage.WebComponent.Tab":"Webov\u00E1 komponenta","BadgePage.TabAriaLabel":"Karta {0}","BadgePage.TabSelectedAriaLabel":"Vybran\u00E1 karta: {0}","BadgePage.Theme.Header":"Motiv","BadgePage.StaticTheme.Tooltip":"Motiv odzn\u00E1\u010Dku, kter\u00FD se m\u00E1 pou\u017E\u00EDt. Pokyny slou\u017E\u00ED k v\u00FDb\u011Bru tmav\u00E9ho motivu na sv\u011Btl\u00E9m pozad\u00ED a naopak.","BadgePage.WebComponentTheme.Tooltip":"Automatick\u00E9 zji\u0161\u0165ov\u00E1n\u00ED detekuje motiv u\u017Eivatele a zobraz\u00ED odpov\u00EDdaj\u00EDc\u00ED motiv odzn\u00E1\u010Dku.","BadgePage.Title":"Vytvo\u0159te si sv\u016Fj odzn\u00E1\u010Dek aplikace","BadgePage.Tooltip":"Popis.","BadgePage.Guidelines.Tooltip":"Pokyny","BadgePage.False.Option":"Nepravda","BadgePage.True.Option":"Pravda","BadgePage.Direct.Option":"P\u0159\u00EDm\u00E9","BadgePage.Full.Option":"\u00DApln\u00E1","BadgePage.None.Option":"\u017D\u00E1dn\u00E9","BadgePage.Dark.Option":"Tmav\u00FD","BadgePage.Light.Option":"Sv\u011Btl\u00E9","BadgePage.Off.Option":"Vypnuto","BadgePage.On.Option":"Zapnuto","BadgePage.AutoDetect.Option":"Automatick\u00E9 rozpozn\u00E1v\u00E1n\u00ED","BadgePage.GenerateBadge":"Vygenerovat odzn\u00E1\u010Dek","BadgePage.CopiedClipboard":"Zkop\u00EDrov\u00E1no do schr\u00E1nky!","BadgePage.StaticBadge.Title":"Statick\u00FD odzn\u00E1\u010Dek","BadgePage.StaticBadge.SimpleDescription":"Jednoduch\u00FD odzn\u00E1\u010Dek se standardn\u00EDm obr\u00E1zkem a odkazem.","BadgePage.StaticBadge.Description":"Tento odzn\u00E1\u010Dek je ide\u00E1ln\u00ED pro soubory README, weby dokumentace, prost\u0159ed\u00ED se z\u00E1sadami zabezpe\u010Den\u00ED obsahu nebo prost\u0159ed\u00ED se zak\u00E1zan\u00FDmi extern\u00EDmi skripty.\u00A0","BadgePage.WebComponentBadge.Title":"Odzn\u00E1\u010Dek webov\u00E9 komponenty","BadgePage.WebComponentBadge.SimpleDescription":"Dynamick\u00FD interaktivn\u00ED odzn\u00E1\u010Dek vytvo\u0159en\u00FD jako webov\u00E1 komponenta.","BadgePage.WebComponentBadge.Description":"Tento odzn\u00E1\u010Dek je zalo\u017Een\u00FD na JavaScriptu a nab\u00EDz\u00ED modern\u00ED funkce, v\u010Detn\u011B automatick\u00E9ho zji\u0161\u0165ov\u00E1n\u00ED n\u00E1rodn\u00EDho prost\u0159ed\u00ED a motivu, stejn\u011B jako plynulou animaci p\u0159i p\u0159echodu my\u0161\u00ED. Tuto mo\u017Enost zvolte, pokud chcete, aby va\u0161e u\u017Eivatel\u00E9 m\u011Bli to nejlep\u0161\u00ED a nejv\u00EDce p\u0159izp\u016Fsoben\u00E9 prost\u0159ed\u00ED.","BadgePage.GetStarted.Title":"Za\u010D\u00EDt","BadgePage.GetStarted.Description":"Pokud chcete vygenerovat odzn\u00E1\u010Dek a p\u0159idat ho na web, postupujte podle t\u011Bchto krok\u016F.","BadgePage.GetStarted.Step1.Title":"Vyberte typ odzn\u00E1\u010Dku","BadgePage.GetStarted.Step1.Description":"Zvolte mezi webovou komponentou nebo statick\u00FDm odzn\u00E1\u010Dkem. Pokud si nejste jist\u00ED, statick\u00FD odzn\u00E1\u010Dek je jistou volbou.","BadgePage.GetStarted.Step2.Title":"Zadejte ID aplikace","BadgePage.GetStarted.Step2.Description":"Do textov\u00E9ho pole vlo\u017Ete 12znakov\u00E9 ID aplikace (kter\u00E9 najdete na \u0159\u00EDdic\u00EDm panelu Partnersk\u00E9ho centra).","BadgePage.GetStarted.Step3.Title":"Zvolit vlastnosti","BadgePage.GetStarted.Step3.Description":"P\u0159izp\u016Fsobte si jazyk, motiv a c\u00EDle spu\u0161t\u011Bn\u00ED nebo p\u0159idejte ID kampan\u011B pro sledov\u00E1n\u00ED v\u00FDkonu.","BadgePage.GetStarted.Step4.Title":"Zkop\u00EDrujte k\u00F3d","BadgePage.GetStarted.Step4.Description":"Klikn\u011Bte na Vygenerovat odzn\u00E1\u010Dek a vlo\u017Ete fragment k\u00F3du p\u0159\u00EDmo do k\u00F3du va\u0161eho webu.","BadgePage.Guidelines.Title":"Pokyny a osv\u011Bd\u010Den\u00E9 postupy","BadgePage.Guidelines.Description":"Postupujte podle t\u011Bchto osv\u011Bd\u010Den\u00FDch postup\u016F a maximalizujte m\u00EDru konverze a dodr\u017Eujte konzistenci zna\u010Dky.","BadgePage.Guidelines.KeepItClear.Title":"Udr\u017Eujte p\u0159ehlednost","BadgePage.Guidelines.KeepItClear.Description":"Udr\u017Eujte standardn\u00ED mezery kolem odzn\u00E1\u010Dku. Nezapl\u0148ujte je jin\u00FDm textem nebo grafikou.","BadgePage.Guidelines.PlaceProminent.Title":"Um\u00EDst\u011Bte ho z\u0159eteln\u011B","BadgePage.Guidelines.PlaceProminent.Description":"Pro dosa\u017Een\u00ED nejlep\u0161\u00EDch m\u00EDry prokliku um\u00EDst\u011Bte odznak \u201Enad okrajem\u201C na svou domovskou str\u00E1nku nebo p\u0159\u00EDmo vedle seznamu hlavn\u00EDch funkc\u00ED va\u0161\u00ED aplikace.","BadgePage.Guidelines.DontAlter.Title":"Nem\u011B\u0148te obr\u00E1zek","BadgePage.Guidelines.DontAlter.Description":"Vygenerovan\u00FD k\u00F3d pou\u017Eijte p\u0159\u00EDmo. Neroztahujte, nep\u0159ebarvujte ani neupravujte grafiku odzn\u00E1\u010Dku, proto\u017Ee to poru\u0161uje pokyny Microsoft Storu pro zna\u010Dku.","BadgePage.Guidelines.CampaignId.Title":"P\u0159id\u00E1n\u00ED ID kampan\u011B pro sledov\u00E1n\u00ED v\u00FDkonu","BadgePage.Guidelines.CampaignId.Description":"P\u0159ipojen\u00ED ID kampan\u011B umo\u017E\u0148uje sledovat n\u00E1v\u0161t\u011Bvn\u00EDky a konverze, co\u017E usnad\u0148uje experimentov\u00E1n\u00ED s r\u016Fzn\u00FDmi um\u00EDst\u011Bn\u00EDmi. Koneckonc\u016F nem\u016F\u017Eete zlep\u0161it to, co nem\u011B\u0159\u00EDte!","BadgePage.Guidelines.DownloadLink":"St\u00E1hnout \u00FApln\u00E9 pokyny (PDF)","BadgePage.FAQ.Title":"\u010Cast\u00E9 ot\u00E1zky","BadgePage.FAQ.FindAppId.Question":"Kde najdu svoje 12m\u00EDstn\u00E9 ID aplikace (ID produktu)?","BadgePage.FAQ.FindAppId.Answer1":"ID va\u0161\u00ED aplikace (ozna\u010Dovan\u00E9 tak\u00E9 jako ID produktu) je jedine\u010Dn\u00FD 12m\u00EDstn\u00FD alfanumerick\u00FD k\u00F3d p\u0159i\u0159azen\u00FD k va\u0161\u00ED aplikaci. Najdete ho na \u0159\u00EDdic\u00EDm panelu pro Partnersk\u00E9 centrum pro Windows. P\u0159ejd\u011Bte na str\u00E1nku aplikace, vyberte Spr\u00E1va aplikace \u003E Identita aplikace a vyhledejte hodnotu \u201EID pro Store\u201C.","BadgePage.FAQ.FindAppId.Answer2":"P\u0159\u00EDpadn\u011B m\u016F\u017Eete svou aplikaci naj\u00EDt na apps.microsoft.com. ID aplikace je 12m\u00EDstn\u00FD k\u00F3d na konci adresy URL: apps.microsoft.com/detail/\u003CAppID\u003E.","BadgePage.FAQ.TrackDownloads.Question":"Jak sledovat, kolik stahov\u00E1n\u00ED se generuje z m\u00E9ho webu?","BadgePage.FAQ.TrackDownloads.Answer":"V\u00FDkon odzn\u00E1\u010Dku m\u016F\u017Eete sledovat p\u0159id\u00E1n\u00EDm ID kampan\u011B (cid) do odkazu na odzn\u00E1\u010Dek. P\u0159i generov\u00E1n\u00ED v\u00FD\u0161e uveden\u00E9ho odzn\u00E1\u010Dku zadejte n\u00E1zev vlastn\u00ED kampan\u011B (nap\u0159. \u201Efooapp_website\u201C). V Sestav\u011B z\u00EDsk\u00E1v\u00E1n\u00ED informac\u00ED v Partnersk\u00E9m centru pak m\u016F\u017Eete zobrazit m\u00EDry prokliku a \u00FAdaje o konverzi p\u0159idru\u017Een\u00E9 k dan\u00E9 kampani.","BadgePage.FAQ.WhichBadgeType.Question":"Jak\u00FD typ odzn\u00E1\u010Dku m\u00E1m zvolit: Statick\u00FD nebo Webov\u00E1 komponenta?","BadgePage.FAQ.WhichBadgeType.Answer1":"Zvolte webovou komponentu pro nejlep\u0161\u00ED u\u017Eivatelsk\u00E9 prost\u0159ed\u00ED na modern\u00EDch webech. Automaticky rozpozn\u00E1 jazyk syst\u00E9mu u\u017Eivatele, aktualizuje se tak, aby odpov\u00EDdal aktu\u00E1ln\u00EDmu jazyku n\u00E1vrhu Microsoftu, a poskytuje animace plynul\u00E9ho p\u0159echodu my\u0161\u00ED.","BadgePage.FAQ.WhichBadgeType.Answer2":"Pokud va\u0161e platforma omezuje JavaScript (nap\u0159\u00EDklad GitHub READMEs, WordPress bez vlastn\u00EDho JS nebo striktn\u00ED prost\u0159ed\u00ED z\u00E1sad zabezpe\u010Den\u00ED obsahu), zvolte statick\u00FD odzn\u00E1\u010Dek.","BadgePage.FAQ.UpdateBadge.Question":"Mus\u00EDm si odzn\u00E1\u010Dek aktualizovat, pokud Microsoft Store zm\u011Bn\u00ED sv\u016Fj branding?","BadgePage.FAQ.UpdateBadge.Answer":"Pokud pou\u017E\u00EDv\u00E1te odzn\u00E1\u010Dky vygenerovan\u00E9 z t\u00E9to str\u00E1nky, ne. Prost\u0159edky hostuje Microsoft a automaticky aktualizuje v\u00E1\u0161 odzn\u00E1\u010Dek tak, aby odr\u00E1\u017Eel v\u0161echny budouc\u00ED zm\u011Bny v rebrandingu nebo n\u00E1vrhu.","BadgePage.FAQ.ResizeBadge.Question":"M\u016F\u017Eu zm\u011Bnit velikost odzn\u00E1\u010Dku tak, aby odpov\u00EDdal n\u00E1vrhu webu?","BadgePage.FAQ.ResizeBadge.Answer":"Odzn\u00E1\u010Dek webov\u00E9 komponenty je p\u0159irozen\u011B responzivn\u00ED a bude se odpov\u00EDdaj\u00EDc\u00EDm zp\u016Fsobem \u0161k\u00E1lovat. Pokud pou\u017E\u00EDv\u00E1te statick\u00FD obr\u00E1zek, m\u016F\u017Eete obr\u00E1zek \u0161k\u00E1lovat pomoc\u00ED \u0161ablon styl\u016F CSS (nap\u0159\u00EDklad \u00FApravou maxim\u00E1ln\u00ED \u0161\u00ED\u0159ky), ale mus\u00EDte zachovat p\u016Fvodn\u00ED pom\u011Br stran. Nikdy neprov\u00E1d\u011Bjte rozta\u017Een\u00ED, zkosen\u00ED ani o\u0159\u00EDznut\u00ED obr\u00E1zku.","BadgePage.FAQ.DarkMode.Question":"Podporuje odzn\u00E1\u010Dek tmav\u00FD re\u017Eim?","BadgePage.FAQ.DarkMode.Answer":"Ano. Odzn\u00E1\u010Dek Webov\u00E1 komponenta dok\u00E1\u017Ee automaticky rozpoznat syst\u00E9mov\u00FD motiv u\u017Eivatele nebo motiv CSS va\u0161eho webu a zobrazit bu\u010F tmavou, nebo sv\u011Btlou variantu. M\u016F\u017Eete tak\u00E9 vynutit, aby se v\u017Edy zobrazoval v tmav\u00E9m nebo sv\u011Btl\u00E9m re\u017Eimu pomoc\u00ED n\u00E1stroj\u016F gener\u00E1toru v\u00FD\u0161e.","BadgePage.SideNav.GetStarted":"Za\u010D\u00EDt","BadgePage.SideNav.BuildYourBadge":"Vytvo\u0159en\u00ED odzn\u00E1\u010Dku","BadgePage.SideNav.StaticBadge":"Statick\u00FD odzn\u00E1\u010Dek","BadgePage.SideNav.WebComponentBadge":"Odzn\u00E1\u010Dek webov\u00E9 komponenty","BadgePage.SideNav.Guidelines":"Pokyny","BadgePage.SideNav.FAQ":"\u010Cast\u00E9 ot\u00E1zky","Common.CollectionsTitle":"Kolekce","CollectionReel.