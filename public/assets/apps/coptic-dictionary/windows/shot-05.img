ollection.Name.MostPopular":"Nejpopul\u00E1rn\u011Bj\u0161\u00ED","Collection.Category.ActionAdventure":"Ak\u010Dn\u00ED a adventury","Collection.Category.BooksReference":"Knihy a p\u0159\u00EDru\u010Dky","Collection.Category.Business":"Pr\u00E1ce","Collection.Category.CardBoard":"Karetn\u00ED a\u00A0deskov\u00E9 hry","Collection.Category.Casino":"Kasino","Collection.Category.Classics":"Klasick\u00E9 hry","Collection.Category.Companion":"Pr\u016Fvodce","Collection.Category.DeveloperTools":"V\u00FDvoj\u00E1\u0159sk\u00E9 n\u00E1stroje","Collection.Category.Education":"Vzd\u011Bl\u00E1v\u00E1n\u00ED","Collection.Category.Educational":"Vzd\u011Bl\u00E1vac\u00ED po\u0159ad","Collection.Category.Entertainment":"Z\u00E1bava","Collection.Category.FamilyKids":"Rodina a d\u011Bti","Collection.Category.Fighting":"Bojov\u00E9 hry","Collection.Category.FoodDining":"Potraviny a j\u00EDdlo","Collection.Category.GovernmentPolitics":"Vl\u00E1da a politika","Collection.Category.HealthFitness":"Zdrav\u00ED a fitness","Collection.Category.KidsFamily":"D\u011Bti a rodina","Collection.Category.Lifestyle":"\u017Divotn\u00ED styl","Collection.Category.Media":"M\u00E9dia","Collection.Category.Medical":"Zdravotn\u00ED probl\u00E9m","Collection.Category.MultimediaDesign":"Multimedi\u00E1ln\u00ED design","Collection.Category.MultiPlayerOnlineBattleArena":"Online bitevn\u00ED ar\u00E9na pro mnoho hr\u00E1\u010D\u016F","Collection.Category.Music":"Hudba","Collection.Category.NavigationMaps":"Navigace \u002B mapy","Collection.Category.NewsWeather":"Zpr\u00E1vy a po\u010Das\u00ED","Collection.Category.Other":"Jin\u00E9","Collection.Category.PersonalFinance":"Osobn\u00ED finance","Collection.Category.Personalization":"P\u0159izp\u016Fsoben\u00ED","Collection.Category.PhotoVideo":"Fotografie a video","Collection.Category.Platformer":"Plo\u0161inov\u00E9","Collection.Category.Productivity":"Produktivita","Collection.Category.ProductivityBusiness":"Produktivita a podnik\u00E1n\u00ED","Collection.Category.PuzzleTrivia":"Puzzle a minihry","Collection.Category.RacingFlying":"Z\u00E1vod\u011Bn\u00ED a l\u00E9t\u00E1n\u00ED","Collection.Category.RolePlaying":"Rolov\u00E9 (rpg)","Collection.Category.Security":"Zabezpe\u010Den\u00ED","Collection.Category.Shooter":"St\u0159\u00EDle\u010Dky","Collection.Category.Shopping":"Nakupov\u00E1n\u00ED","Collection.Category.Simulation":"Simul\u00E1tory","Collection.Category.Social":"Soci\u00E1ln\u00ED s\u00EDt\u011B","Collection.Category.Sports":"Sport","Collection.Category.Strategy":"Strategick\u00E9","Collection.Category.StrategySimulation":"Strategie a simulace","Collection.Category.Tools":"N\u00E1stroje","Collection.Category.Travel":"Cestov\u00E1n\u00ED","Collection.Category.UtilitiesTools":"N\u00E1stroje","Collection.Category.Video":"Video","Collection.Category.Word":"Word"},"localeStringsFallback":{"AboutPage.DisclaimerPlus":"Screens simulated. Features and app availability may vary by region. Apps, games, and other content/subscriptions sold separately; free apps may contain ads or in-app purchases.","AboutPage.DisclaimerOne":"Only applicable to select regions.","AboutPage.DisclaimerTwo":"Apps in the Store distributed by its own developer are updated separately by that developer.","AboutPage.DisclaimerThree":"Secure payment methods depend on selected content and apps.","AboutPage.SocialApps":"SOCIAL NETWORKING APPS","AboutPage.SocialAppsSubtitle":"Connect and learn","AboutPage.ProductivityApps":"PRODUCTIVITY APPS","AboutPage.ProductivityAppsSubtitle":"Achieve more from anywhere","AboutPage.ClassicGames":"CLASSIC GAMES","AboutPage.ClassicGamesSubtitle":"Classics that never get old","AboutPage.ExploreMore":"Explore More","AboutPage.ExploreNow":"Explore now","AboutPage.ImageAlt":"A background image of the info banner.","AboutPage.Title":"Apps and games for work and play","AboutPage.MetaTitle":"Discover and Explore Apps and Games at Microsoft Store","AboutPage.MetaDescription":"Explore a vast selection of secure apps and games at Microsoft Store. Learn why it\u0027s the go-to destination for safe and reliable downloads. Discover more today!","AboutPage.Number":"Jump to subscript {0}","AboutPage.GamingTitle":"Desktop gaming","AboutPage.GamingDescription":"Play PC games from award-winning Indie game developers to AAA publishers","AboutPage.ExploreGames":"Explore games","AboutPage.ExploreApps":"Explore apps","AboutPage.RewardsTitle":"Rewards","AboutPage.RewardsDescription":"Earn Microsoft Rewards points when you buy products from the Store in participating regions. Redeem points for gift cards, donations, and sweepstake entries.","AboutPage.AiHub":"AI Hub","AboutPage.AiHubDescription":"A new place to get high quality AI-powered apps to boost your productivity and creativity","AboutPage.TrustworthyTitle":"Trustworthy and secure","AboutPage.TrustworthyDescription":"Download safely with verified apps, so you can trust what you install","AboutPage.CertificationTitle":"Strict verification process","AboutPage.CertificationDescription":"All apps are scanned for known malware and safety issues. We also check compatibility for you before you acquire the app.","AboutPage.FamilySafetyTitle":"Family safety","AboutPage.FamilySafetyDescription":"Create a safer digital environment for kids and teens, with purchase protections and safeguards for age-appropriate apps and games","AboutPage.TrustedPaymentTitle":"Safeguarded transactions","AboutPage.TrustedPaymentDescription":"Keep your transaction secure with trusted ways to pay and check out while protecting your assets","AboutPage.ExperienceTitle":"Seamless experience on Windows","AboutPage.ExperienceDescription":"Easy install and quick check out across Microsoft devices","AboutPage.ConnectedAccount":"Your apps on all your devices","AboutPage.ConnectedAccountDescription":"Purchases and downloads of apps or games from the Store will be linked to your Microsoft Account, so when you acquire a product on one device, you can restore it on your other devices at no additional cost.","AboutPage.PlayAnywhere":"Play anywhere","AboutPage.PlayAnywhereDescription":"Participating games purchased from the Microsoft Store on your PC can be installed on your Xbox at no additional cost. And the reverse is true as well: participating games purchased on your Xbox console can be installed on your PC.","AboutPage.EfficientUpdates":"Efficient updates","AboutPage.EfficientUpdatesDescription":"The Microsoft Store and Windows work together to ensure apps from the Store efficiently receive updates in the background","AboutPage.DiscoverTitle":"Discover","AboutPage.DiscoverDescription":"Watch shows from your favorite streaming app, make digital art with creativity software, or get work done with powerful productivity tools","AboutPage.Description":"Find your favorite apps. Relax and unleash your creativity and productivity.","AboutPage.Banner.Title":"Everything you want, right where you want it","AboutPage.Banner.ToStoreAppLabel":"Explore now","AboutPage.MicrosoftStoreTitle":"Microsoft Store App","AboutPage.MicrosoftStoreDescription":"Get the Microsoft Store app for a better experience discovering and updating apps and games on Windows.","AboutPage.MicrosoftStoreLogoAlt":"Microsoft Store Logo","AboutPage.DownloadStoreButton":"Download Store app","AboutPage.GetStoreAppButton":"Get the Microsoft Store App","AboutPage.NoStoreQuestion":"Don\u0027t have the Microsoft Store app on your device?","AboutPage.DownloadStorePromptLine1":"If you don\u0027t have the Microsoft Store app on your device,","AboutPage.DownloadStorePromptLine2":"click {0} to download it now.","AboutPage.DownloadStoreLink":"here","AboutPage.SeamlessExperience":"on your Windows devices","AboutPage.TrustedDownload":"Trusted Downloads","AboutPage.AIIntegrated":"AI Integrated","AboutPage.AutomaticUpdates":"Auto Update","AboutPage.TrustedDownloadText":"Secure","AboutPage.AIIntegratedText":"Copilot","AgeVerification.MatureContentSignInRestriction":"Sign in to view this content","AgeVerification.MatureContentSignInSubtitle":"We need to verify your age to ensure this content is age-appropriate.","AgeVerification.MatureContentSignInButton":"Sign in","AgeVerification.MatureContentUnverifiedRestriction":"Verify your age to view this content","AgeVerification.MatureContentUnverifiedSubtitle":"Your account requires age verification before viewing age-restricted content.","AgeVerification.MatureContentUnverifiedButton":"Verify","AgeVerification.MatureContentRestriction":"Your account doesn\u0027t meet the minimum age requirements to view this content.","BuyBox.Tooltip.SignInRequired":"You must sign in to get this app.","BuyBox.Tooltip.AgeBlocked":"Your account does not meet the age requirements for this product.","BuyBox.Tooltip.VerifyRequired":"You must verify your age to get this app.","AlertService.Retry":"Retry","AlertService.SwitchAccount":"Switch Account","AuthService.SignInError":"We encountered an error. Please try again.","AuthService.PopupBlockedError":"Make sure your popup blocker is disabled on this site in order to sign in.","AuthRedirect.Title":"Signed out","AuthRedirect.Description":"You are now signed out.","BadgePage.AppID.Header":"App ID","BadgePage.AppID.Invalid.Tooltip":"Product ID should be 12 characters, unless ID begins with XP, in which case it should be 14 characters.","BadgePage.AppID.Tooltip":"The ID of your app. You can find this in Microsoft Partner Center, or as the end of the URL of your app on this site, e.g. https://apps.microsoft.com/detail/9MV0B5HZVK9Z","BadgePage.AutoLaunch.Header":"Auto-Launch","BadgePage.AutoLaunch.Tooltip":"If Launch Mode is Full and Auto Launch is true, clicking the badge will open the Store app automatically.","BadgePage.BadgeText":"Download from the Microsoft Store","BadgePage.ButtonAriaLabel":"{0} button","BadgePage.CID.Header":"Campaign ID","BadgePage.CID.Tooltip":"The campaign code of your app. You can find this in Microsoft Partner Center.","BadgePage.Description":"The Microsoft Store app badge is the best way for you to display, direct, and track traffic from your assets to the Microsoft Store listing.","BadgePage.UpdateDescription":"UPDATE: Badges that don\u0027t have a launch surface set will now default to the direct download type. The auto-launch option will not be available for direct downloads. Existing JavaScript based badges that used the \u0022pop up\u0022 type will also default to the direct download type.","BadgePage.UpdatePopupDescription":"To continue using the popup Store, please re-generate the badge and use the new code.","BadgePage.Preview.Tab":"Preview","BadgePage.CodeSnippet.Tab":"Code Snippet","BadgePage.Optional.Text":"(Optional)","BadgePage.Interaction.Header":"Interaction Animation","BadgePage.Interaction.Tooltip":"The badge animation on hover and pressed states.","BadgePage.Language.Header":"Language","BadgePage.StaticLanguage.Tooltip":"Choose a language to render the badge in.","BadgePage.WebComponentLanguage.Tooltip":"Auto detect (recommended) renders the badge in the language of the user\u0027s browser. Alternately, choose a language to always render the badge in that language.","BadgePage.Launch.Header":"Launch Mode","BadgePage.Launch.Tooltip":"The launch mode for your app when users click on your badge. Direct mode downloads your app\u0027s installer executable and is the default. Full mode opens your app\u0027s product page on Store app.","BadgePage.WebComponent.Tab":"Web Component","BadgePage.TabAriaLabel":"{0} tab","BadgePage.TabSelectedAriaLabel":"Selected {0} tab","BadgePage.Theme.Header":"Theme","BadgePage.StaticTheme.Tooltip":"The badge theme to use. Guidance is to choose dark on light backgrounds and vise-versa.","BadgePage.WebComponentTheme.Tooltip":"Auto Detect will detect the user\u0027s theme and display the corresponding badge theme.","BadgePage.Title":"Build your app badge","BadgePage.Tooltip":"Tooltip.","BadgePage.Guidelines.Tooltip":"Guidelines","BadgePage.False.Option":"False","BadgePage.True.Option":"True","BadgePage.Direct.Option":"Direct","BadgePage.Full.Option":"Full","BadgePage.None.Option":"None","BadgePage.Dark.Option":"Dark","BadgePage.Light.Option":"Light","BadgePage.Off.Option":"Off","BadgePage.On.Option":"On","BadgePage.AutoDetect.Option":"Auto Detect","BadgePage.GenerateBadge":"Generate your badge","BadgePage.CopiedClipboard":"Copied to clipboard!","BadgePage.StaticBadge.Title":"Static badge","BadgePage.StaticBadge.SimpleDescription":"A simple, lightweight badge using a standard image and link.","BadgePage.StaticBadge.Description":"This badge is ideal for READMEs, documentation sites, environments with Content Security Policies, or anywhere external scripts are restricted.\u00A0","BadgePage.WebComponentBadge.Title":"Web component badge","BadgePage.WebComponentBadge.SimpleDescription":"A dynamic, interactive badge built as a web component.","BadgePage.WebComponentBadge.Description":"This badge is JavaScript-based and offers modern features including automatic locale and theme detection as well as a smooth hover animation. Choose this option when you want the best, most customized experience for your users.","BadgePage.GetStarted.Title":"Get started","BadgePage.GetStarted.Description":"Follow these steps to generate your badge and add it to your website.","BadgePage.GetStarted.Step1.Title":"Pick a badge type","BadgePage.GetStarted.Step1.Description":"Choose between a Web component or Static badge. If you\u0027re unsure, the static badge is a safe bet.","BadgePage.GetStarted.Step2.Title":"Enter your App ID","BadgePage.GetStarted.Step2.Description":"Paste your 12-character App ID (found in your Partner Center dashboard) into the textbox.","BadgePage.GetStarted.Step3.Title":"Select properties","BadgePage.GetStarted.Step3.Description":"Customize the language, theme, and launch targets, or add a campaign ID to track performance.","BadgePage.GetStarted.Step4.Title":"Copy the code","BadgePage.GetStarted.Step4.Description":"Click \u0022Generate your badge\u0022 and paste the snippet directly into your website\u0027s code.","BadgePage.Guidelines.Title":"Guidelines \u0026 best practices","BadgePage.Guidelines.Description":"Follow these best practices to maximize your conversion rates and maintain brand consistency.","BadgePage.Guidelines.KeepItClear.Title":"Keep it clear","BadgePage.Guidelines.KeepItClear.Description":"Maintain standard spacing around the badge. Don\u0027t crowd it with other text or graphics.","BadgePage.Guidelines.PlaceProminent.Title":"Place it prominently","BadgePage.Guidelines.PlaceProminent.Description":"For the best click-through rates, place the badge \u0022above the fold\u0022 on your homepage, or directly next to your app\u0027s primary features list.","BadgePage.Guidelines.DontAlter.Title":"Don\u0027t alter the artwork","BadgePage.Guidelines.DontAlter.Description":"Use the generated code directly. Do not stretch, recolor, or modify the badge graphics, as this violates the Microsoft Store brand guidelines.","BadgePage.Guidelines.CampaignId.Title":"Add a campaign ID to track performance","BadgePage.Guidelines.CampaignId.Description":"Appending a campaign ID allows you to track visitors and conversions, making it easy to experiment with different placements. After all, you can\u0027t improve what you don\u0027t measure!","BadgePage.Guidelines.DownloadLink":"Download full guidelines (PDF)","BadgePage.FAQ.Title":"FAQ","BadgePage.FAQ.FindAppId.Question":"Where can I find my 12-character App ID (Product ID)?","BadgePage.FAQ.FindAppId.Answer1":"Your App ID (also known as the Product ID) is a unique 12-character alphanumeric code assigned to your app. You can find it in your Windows Partner Center dashboard. Navigate to your app\u0027s page, select App management \u003E App identity, and look for the \u0022Store ID\u0022 value.","BadgePage.FAQ.FindAppId.Answer2":"Alternatively, you can find your app on apps.microsoft.com. Your App ID is the 12-character code at the end of the URL: apps.microsoft.com/detail/\u003CAppID\u003E.","BadgePage.FAQ.TrackDownloads.Question":"How do I track how many downloads are generated from my website?","BadgePage.FAQ.TrackDownloads.Answer":"You can track badge performance by adding a Campaign ID (cid) to your badge link. When generating your badge above, enter a custom campaign name (e.g., \u0022fooapp_website\u0022). You can then view the click-through rates and conversion data associated with that specific campaign in your Partner Center Acquisition Report.","BadgePage.FAQ.WhichBadgeType.Question":"Which badge type should I choose: Static or Web Component?","BadgePage.FAQ.WhichBadgeType.Answer1":"Choose the Web Component for the best user experience on modern websites. It automatically detects the user\u0027s system language, updates to match Microsoft\u0027s current design language, and provides smooth hover animations.","BadgePage.FAQ.WhichBadgeType.Answer2":"Choose the Static badge if your platform restricts JavaScript (like GitHub READMEs, WordPress without custom JS, or strict Content Security Policy environments).","BadgePage.FAQ.UpdateBadge.Question":"Do I need to update my badge if the Microsoft Store changes its branding?","BadgePage.FAQ.UpdateBadge.Answer":"If you are using the badges generated from this page, no. The assets are hosted by Microsoft and will automatically update your badge to reflect any future rebranding or design changes.","BadgePage.FAQ.ResizeBadge.Question":"Can I resize the badge to fit my website\u0027s design?","BadgePage.FAQ.ResizeBadge.Answer":"The Web Component badge is naturally responsive and will scale appropriately. If you are using the Static image, you can scale the image using CSS (e.g., adjusting the max-width), but you must preserve the original aspect ratio. Never stretch, skew, or crop the image.","BadgePage.FAQ.DarkMode.Question":"Does the badge support dark mode?","BadgePage.FAQ.DarkMode.Answer":"Yes. The Web Component badge can automatically detect the user\u0027s system theme or your website\u0027s CSS theme and display either a dark or light variant. You can also force it to always display in dark or light mode using the generator tools above.","BadgePage.SideNav.GetStarted":"Get started","BadgePage.SideNav.BuildYourBadge":"Build your badge","BadgePage.SideNav.StaticBadge":"Static badge","BadgePage.SideNav.WebComponentBadge":"Web component badge","BadgePage.SideNav.Guidelines":"Guidelines","BadgePage.SideNav.FAQ":"FAQ","Common.CollectionsTitle":"Collections","CollectionReel.PlayButton":"Play the animation on the collection reel","CollectionReel.PauseButton":"Pause the animation on the collection reel","Common.PageTitle":"{0} - Microsoft Apps","Common.PageAppsTitle":"{0} - Download and install on Windows | Microsoft Store","Common.PageAppsFreeTitle":"{0} - Free download and install on Windows | Microsoft Store","Common.PageGameTitle":"{0} - Download and play on Windows | Microsoft Store","Common.PageGameFreeTitle":"{0} - Free download and play on Windows | Microsoft Store","MsStoreDetails.PageTitle":"Download and install Microsoft Store app on Windows","Common.ScrollLeft.ButtonTitle":"Scroll left","Common.ScrollRight.ButtonTitle":"Scroll right","Common.ScrollToTop.ButtonTitle":"Scroll to top","Common.SeeAll":"See all","Common.SeeAllTitle":"See all {0}. Use arrow keys to browse through the items","Collection.LoadMore":"Show more","Common.SeeDetails":"See details","Common.AdBadge":"Ad","Common.MenuItemSelected":"{0} selected","Common.SpotlightCard":"{0}, {1} of {2}","Common.SpotlightDotButton":"Slide {0}: {1}","Common.SpotlightDotButtonSelected":"Slide {0}: {1}, selected","Common.ProductCardPosition":"{0}, {1} of {2}","Common.Description":"Description","Common.Ellipsis":"{0}...","Common.LearnMore":"Learn more","Common.App":"app","Common.SpecialOffers":"Special offers that won\u0027t last forever","Common.CuratedEvents":"Curated events","Common.UnableToConnect":"Unable to connect","Common.UnableToConnectDetails":"There was a problem loading data. Refreshing