        window.pageMetadata = {"shortDescription":"Offline Coptic dictionary and study app. Search words and meanings, save vocabulary, quiz yourself, and export study lists.","categoryId":"Education","categoryIds":["Education"],"subcategoryName":"U\u010Den\u00ED jazyk\u016F","approximateSizeInBytes":4421095,"capabilities":[],"developerName":"BassThermal","durationInSeconds":0,"hasAddOns":false,"hasThirdPartyIAPs":false,"language":"neutral","maxInstallSizeInBytes":20533248,"mediaType":"Apps","publisherId":"93486540","ratingCount":0,"additionalLicenseTerms":"App \u00A9 BassThermal Labs. Lexicon data adapted from Comprehensive Coptic Lexicon v1.2, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","appWebsiteUrl":"https://www.dualticker.com/","features":["Offline Coptic dictionary search","Search by Coptic word, English meaning, or type-as spelling","Save vocabulary for later study","Quiz yourself on saved words","View word forms, dialect labels, sources, and Greek-origin references","Export saved words as CSV, TSV, JSON, Anki CSV, text, or printable study sheet","Import and restore saved-word backups","Copy words, meanings, citations, and study summaries","Keyboard navigation for fast dictionary browsing","Built from the Comprehensive Coptic Lexicon v1.2","No account required; searches stay on your device"],"gamingOptionsXboxLive":false,"installationTerms":"Z\u00EDskejte tuto aplikaci po p\u0159ihl\u00E1\u0161en\u00ED ke \u00FA\u010Dtu Microsoft a nainstalujte si ji a\u017E na 10 za\u0159\u00EDzen\u00ED s\u00A0Windows.","isMicrosoftProduct":false,"isMsixvc":false,"lastUpdateDateUtc":"2026-04-30T12:31:39Z","permissionsRequired":["Pou\u017E\u00EDv\u00E1 v\u0161echny syst\u00E9mov\u00E9 prost\u0159edky."],"platforms":["x64"],"privacyUrl":"https://cdn.storeedgefd.dsx.mp.microsoft.com/eus2/privacy-policy-storage/93486540/00014493098251600575/1152921505700937663/privacy_policy_9af2b326-0539-4fc9-94ca-e835940d6971.txt","productRatings":[{"ratingSystem":"Pan European Game Information","ratingSystemShortName":"PEGI","ratingSystemId":"PEGI","ratingSystemUrl":"https://pegi.info","ratingValue":"PEGI 3","ratingId":"PEGI:3","ratingValueLogoUrl":"https://store-images.s-microsoft.com/image/global.4635.image.6f55bab8-d894-46ea-94d9-4ad102009096.4211468b-3c13-4a63-9bd3-07385b207b19","ratingAge":3,"restrictMetadata":false,"restrictPurchase":false,"ratingDescriptors":[],"ratingDisclaimers":[],"interactiveElements":[],"longName":"PEGI 3","shortName":"PEGI 3","description":"Od t\u0159\u00ED let","hasInAppPurchases":false}],"publisherAddress":"7807a Henri Julien Avenue,Montr\u00E9al,QC,Canada","publisherCopyrightInformation":"App \u00A9 BassThermal. Lexicon data adapted from Comprehensive Coptic Lexicon v1.2, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","publisherPhoneNumber":"","supportedLanguages":["Angli\u010Dtina (Spojen\u00E9 st\u00E1ty)"],"supportUris":[{"uri":"https://www.dualticker.com/"}],"systemRequirements":{"minimum":{"title":"Minimum","items":[{"level":"HardBlock","itemCode":"dvc","name":"Dostupn\u00E9 na","description":"Po\u010D\u00EDta\u010D","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"OS","description":"Windows 10 verze 17763.0 nebo nov\u011Bj\u0161\u00ED","validationHint":"(po\u017Eadov\u00E1no)","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Kl\u00E1vesnice","description":"Neur\u010Deno","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"My\u0161","description":"Neur\u010Deno","priority":"Default"}]},"recommended":{"title":"Doporu\u010Den\u00E9","items":[{"level":"HardBlock","itemCode":"dvc","name":"Dostupn\u00E9 na","description":"Po\u010D\u00EDta\u010D","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"OS","description":"Windows 10 verze 17763.0 nebo nov\u011Bj\u0161\u00ED","validationHint":"(po\u017Eadov\u00E1no)","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Kl\u00E1vesnice","description":"Integrovan\u00E1 kl\u00E1vesnice","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"My\u0161","description":"Integrovan\u00E1 my\u0161","priority":"Default"}]}},"version":"","pdpImageUrl":"https://store-images.s-microsoft.com/image/apps.41069.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.a32d4aba-c850-4e46-b07a-69756c0c53f7","productId":"9nxmkjl625r2","title":"Coptic Dictionary","description":"Coptic Dictionary is an offline Coptic dictionary and study app for Windows.\n\nSearch Coptic words, English meanings, romanized type-as spellings, dialect forms, Greek-origin references, and source citations in a fast local desktop app. Save vocabulary as you browse, quiz yourself on saved words, and export study lists for learning, teaching, or research.\n\nThe app is built from the Comprehensive Coptic Lexicon v1.2, including Coptic entries and Greek loanword material. It turns scholarly lexicon data into a clean, practical dictionary for Coptic language learners, Egyptology students, researchers, teachers, and anyone studying Coptic vocabulary.\n\nKey tools include offline dictionary search, saved words, quiz mode, forms and dialect labels, source references, Greek-origin indicators, keyboard navigation, study backup import/export, and multiple export formats.\n\nCoptic Dictionary works offline after installation. No account is required. Dictionary searches and saved words stay on your device.\n\nData source attribution: Comprehensive Coptic Lexicon: Including Loanwords from Ancient Greek, edition v1.2, DOI 10.17169/refubium-27566, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","categories":["Vzd\u011Bl\u00E1v\u00E1n\u00ED"],"publisherName":"BassThermal","images":[{"imageType":"logo","backgroundColor":"","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.co