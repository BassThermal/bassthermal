        <script type="application/ld&#x2B;json">
            {"@context":"https://schema.org","@type":"SoftwareApplication","name":"Coptic Dictionary - Descargar e instalar en Windows | Microsoft Store","description":"Coptic Dictionary is an offline Coptic dictionary and study app for Windows.\n\nSearch Coptic words, English meanings, romanized type-as spellings, dialect forms, Greek-origin references, and source citations in a fast local desktop app. Save vocabulary as you browse, quiz yourself on saved words, and export study lists for learning, teaching, or research.\n\nThe app is built from the Comprehensive Coptic Lexicon v1.2, including Coptic entries and Greek loanword material. It turns scholarly lexicon data into a clean, practical dictionary for Coptic language learners, Egyptology students, researchers, teachers, and anyone studying Coptic vocabulary.\n\nKey tools include offline dictionary search, saved words, quiz mode, forms and dialect labels, source references, Greek-origin indicators, keyboard navigation, study backup import/export, and multiple export formats.\n\nCoptic Dictionary works offline after installation. No account is required. Dictionary searches and saved words stay on your device.\n\nData source attribution: Comprehensive Coptic Lexicon: Including Loanwords from Ancient Greek, edition v1.2, DOI 10.17169/refubium-27566, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","image":"https://store-images.s-microsoft.com/image/apps.41069.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.a32d4aba-c850-4e46-b07a-69756c0c53f7","url":"https://apps.microsoft.com/detail/9nxmkjl625r2?hl=es-MX&gl=MX","author":{"@type":"Person","name":"BassThermal","url":"https://apps.microsoft.com/search/publisher?name=BassThermal&hl=es-MX&gl=MX"},"offers":{"@type":"Offer","price":"89","priceCurrency":"USD"},"applicationCategory":"Educación","applicationSubCategory":"Idioma","featureList":["Offline Coptic dictionary search","Search by Coptic word, English meaning, or type-as spelling","Save vocabulary for later study","Quiz yourself on saved words","View word forms, dialect labels, sources, and Greek-origin references","Export saved words as CSV, TSV, JSON, Anki CSV, text, or printable study sheet","Import and restore saved-word backups","Copy words, meanings, citations, and study summaries","Keyboard navigation for fast dictionary browsing","Built from the Comprehensive Coptic Lexicon v1.2","No account required; searches stay on your device"],"operatingSystem":"Windows 10 versión 17763.0 o posterior","screenshot":[{"BackgroundColor":"","ForegroundColor":"","@type":"ImageObject","url":"https://store-images.s-microsoft.com/image/apps.38317.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.964a3d04-aa97-4012-97ff-d47cb2181eba","position":"Desktop/0","height":1126,"width":1919},{"BackgroundColor":"","ForegroundColor":"","@type":"ImageObject","url":"https://store-images.s-microsoft.com/image/apps.62172.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.93381cf0-408f-4308-a8ef-7e8533f7b034","position":"Desktop/1","height":1126,"width":1919},{"BackgroundColor":"","ForegroundColor":"","@type":"ImageObject","url":"https://store-images.s-microsoft.com/image/apps.64540.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.9ba6cc9f-7299-484e-b6f7-0a03d15a353b","position":"Desktop/2","height":1128,"width":1919},{"BackgroundColor":"","ForegroundColor":"","@type":"ImageObject","url":"https://store-images.s-microsoft.com/image/apps.54006.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.33cc830f-1249-428f-b845-e2b7eeb2c5d0","position":"Desktop/3","height":424,"width":478},{"BackgroundColor":"","ForegroundColor":"","@type":"ImageObject","url":"https://store-images.s-microsoft.com/image/apps.18145.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.359c14ae-63ea-4462-8596-fcd468776073","position":"Desktop/4","height":820,"width":1073}]}
