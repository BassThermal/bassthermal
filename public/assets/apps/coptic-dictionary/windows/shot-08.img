        window.pageMetadata = {"shortDescription":"Offline Coptic dictionary and study app. Search words and meanings, save vocabulary, quiz yourself, and export study lists.","categoryId":"Education","categoryIds":["Education"],"subcategoryName":"Language","approximateSizeInBytes":4421095,"capabilities":[],"developerName":"BassThermal","durationInSeconds":0,"hasAddOns":false,"hasThirdPartyIAPs":false,"language":"neutral","maxInstallSizeInBytes":20533248,"mediaType":"Apps","publisherId":"93486540","ratingCount":0,"additionalLicenseTerms":"App \u00A9 BassThermal Labs. Lexicon data adapted from Comprehensive Coptic Lexicon v1.2, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","appWebsiteUrl":"https://www.dualticker.com/","features":["Offline Coptic dictionary search","Search by Coptic word, English meaning, or type-as spelling","Save vocabulary for later study","Quiz yourself on saved words","View word forms, dialect labels, sources, and Greek-origin references","Export saved words as CSV, TSV, JSON, Anki CSV, text, or printable study sheet","Import and restore saved-word backups","Copy words, meanings, citations, and study summaries","Keyboard navigation for fast dictionary browsing","Built from the Comprehensive Coptic Lexicon v1.2","No account required; searches stay on your device"],"gamingOptionsXboxLive":false,"installationTerms":"Obtenez cette application lorsque vous \u00EAtes connect\u00E9 \u00E0 votre compte Microsoft et installez-la sur jusqu\u0027\u00E0 dix\u00A0appareils Windows.","isMicrosoftProduct":false,"isMsixvc":false,"lastUpdateDateUtc":"2026-04-30T12:31:39Z","permissionsRequired":["Uses all system resources"],"platforms":["x64"],"privacyUrl":"https://cdn.storeedgefd.dsx.mp.microsoft.com/eus2/privacy-policy-storage/93486540/00014493098251600575/1152921505700937663/privacy_policy_9af2b326-0539-4fc9-94ca-e835940d6971.txt","productRatings":[{"ratingSystem":"Entertainment Software Rating Board","ratingSystemShortName":"ESRB","ratingSystemId":"ESRB","ratingSystemUrl":"https://www.esrb.org/ratings-guide/","ratingValue":"ENFANTS ET ADULTES","ratingId":"ESRB:E","ratingValueLogoUrl":"https://store-images.microsoft.com/image/global.23456.image.87f616db-3cfc-4611-b3b8-c57bbb87de71.7e7baf95-3edb-4b7c-a960-75e7537b07c9","ratingAge":1,"restrictMetadata":false,"restrictPurchase":false,"ratingDescriptors":[],"ratingDisclaimers":[],"interactiveElements":[],"longName":"ENFANTS ET ADULTES","shortName":"E","description":"Tous les \u00E2ges","hasInAppPurchases":false}],"publisherAddress":"7807a Henri Julien Avenue,Montr\u00E9al,QC,Canada","publisherCopyrightInformation":"App \u00A9 BassThermal. Lexicon data adapted from Comprehensive Coptic Lexicon v1.2, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","publisherPhoneNumber":"","supportedLanguages":["English (United States)"],"supportUris":[{"uri":"https://www.dualticker.com/"}],"systemRequirements":{"minimum":{"title":"Minimum","items":[{"level":"HardBlock","itemCode":"dvc","name":"Disponible sur","description":"PC","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"Syst\u00E8me d\u0027exploitation","description":"Windows 10 version 17763.0 ou version ult\u00E9rieure","validationHint":"obligatoire","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Clavier","description":"Non sp\u00E9cifi\u00E9","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"Souris","description":"Non sp\u00E9cifi\u00E9","priority":"Default"}]},"recommended":{"title":"Nos recommandations","items":[{"level":"HardBlock","itemCode":"dvc","name":"Disponible sur","description":"PC","isValidationPassed":true,"priority":"Default"},{"level":"HardBlock","itemCode":"ops","name":"Syst\u00E8me d\u0027exploitation","description":"Windows 10 version 17763.0 ou version ult\u00E9rieure","validationHint":"obligatoire","isValidationPassed":true,"priority":"Default"},{"level":"SoftBlock","itemCode":"kbd","name":"Clavier","description":"Clavier int\u00E9gr\u00E9","priority":"Default"},{"level":"SoftBlock","itemCode":"mse","name":"Souris","description":"Souris int\u00E9gr\u00E9e","priority":"Default"}]}},"version":"","pdpImageUrl":"https://store-images.s-microsoft.com/image/apps.41069.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.a32d4aba-c850-4e46-b07a-69756c0c53f7","productId":"9nxmkjl625r2","title":"Coptic Dictionary","description":"Coptic Dictionary is an offline Coptic dictionary and study app for Windows.\n\nSearch Coptic words, English meanings, romanized type-as spellings, dialect forms, Greek-origin references, and source citations in a fast local desktop app. Save vocabulary as you browse, quiz yourself on saved words, and export study lists for learning, teaching, or research.\n\nThe app is built from the Comprehensive Coptic Lexicon v1.2, including Coptic entries and Greek loanword material. It turns scholarly lexicon data into a clean, practical dictionary for Coptic language learners, Egyptology students, researchers, teachers, and anyone studying Coptic vocabulary.\n\nKey tools include offline dictionary search, saved words, quiz mode, forms and dialect labels, source references, Greek-origin indicators, keyboard navigation, study backup import/export, and multiple export formats.\n\nCoptic Dictionary works offline after installation. No account is required. Dictionary searches and saved words stay on your device.\n\nData source attribution: Comprehensive Coptic Lexicon: Including Loanwords from Ancient Greek, edition v1.2, DOI 10.17169/refubium-27566, licensed under Creative Commons Attribution-ShareAlike 4.0 International.","categories":["Education"],"publisherName":"BassThermal","images":[{"imageType":"logo","backgroundColor":"","foregroundColor":"","caption":"","imagePositionInfo":"","url":"https://store-images.s-microsoft.com/image/apps.41069.14493098251600575.fd15d556-c4e9-4928-8dc2-796ea45e7467.a32d4aba-c8