        window.pageLocalizer = {"hl":"fr-CA","gl":"CA","uiLocale":"fr-CA","marketDetails":{"market":"CA","tier":1},"isEmbargoedMarket":false,"localeStrings":{"AboutPage.DisclaimerPlus":"\u00C9crans simul\u00E9s. Les fonctionnalit\u00E9s et la disponibilit\u00E9 des applications peuvent varier selon les r\u00E9gions. Applications, jeux et autres contenus/abonnements vendus s\u00E9par\u00E9ment; les applications gratuites peuvent contenir des annonces publicitaires ou des achats dans l\u2019application.","AboutPage.DisclaimerOne":"Applicable uniquement \u00E0 certaines r\u00E9gions.","AboutPage.DisclaimerTwo":"Les applications de Microsoft Store distribu\u00E9es par leur propre d\u00E9veloppeur sont mises \u00E0 jour s\u00E9par\u00E9ment par ce d\u00E9veloppeur.","AboutPage.DisclaimerThree":"Les modes de paiement s\u00E9curis\u00E9s d\u00E9pendent du contenu et des applications s\u00E9lectionn\u00E9s.","AboutPage.SocialApps":"APPLICATIONS DE R\u00C9SEAUX SOCIAUX","AboutPage.SocialAppsSubtitle":"Se connecter et d\u00E9couvrir","AboutPage.ProductivityApps":"APPLICATIONS PRODUCTIVIT\u00C9","AboutPage.ProductivityAppsSubtitle":"R\u00E9alisez plus de choses de n\u2019importe o\u00F9","AboutPage.ClassicGames":"JEUX CLASSIQUES","AboutPage.ClassicGamesSubtitle":"Classiques intemporels","AboutPage.ExploreMore":"En voir plus","AboutPage.ExploreNow":"Explorer d\u00E8s maintenant","AboutPage.ImageAlt":"Image d\u2019arri\u00E8re-plan de la banni\u00E8re d\u2019informations.","AboutPage.Title":"Applications et jeux pour le travail et les loisirs","AboutPage.MetaTitle":"D\u00E9couvrir et explorer des applications et des jeux sur le Microsoft Store","AboutPage.MetaDescription":"Explorer une vaste s\u00E9lection d\u2019applications et de jeux s\u00E9curis\u00E9s sur le Microsoft Store. D\u00E9couvrir pourquoi il s\u2019agit de la r\u00E9f\u00E9rence privil\u00E9gi\u00E9e pour des t\u00E9l\u00E9chargements fiables et s\u00E9curis\u00E9s. En savoir plus plus d\u00E8s aujourd\u2019hui.","AboutPage.Number":"Acc\u00E9der \u00E0 l\u2019index {0}","AboutPage.GamingTitle":"Jeux pour PC","AboutPage.GamingDescription":"Jouez \u00E0 des jeux pour PC de d\u00E9veloppeurs de jeux ind\u00E9pendants et d\u2019\u00E9diteurs AAA renomm\u00E9s","AboutPage.ExploreGames":"Explorer les jeux","AboutPage.ExploreApps":"Explorer les applications","AboutPage.RewardsTitle":"Rewards","AboutPage.RewardsDescription":"Gagnez des points Microsoft\u00A0Rewards lorsque vous achetez des produits dans le Store dans les r\u00E9gions participantes. \u00C9changez des points contre des cartes cadeaux, des dons et des participations \u00E0 des tirages au sort.","AboutPage.AiHub":"Centre d\u2019IA","AboutPage.AiHubDescription":"Un nouvel emplacement pour obtenir des applications haute qualit\u00E9 bas\u00E9es sur l\u2019IA pour am\u00E9liorer votre productivit\u00E9 et votre cr\u00E9ativit\u00E9.","AboutPage.TrustworthyTitle":"Digne de confiance et s\u00E9curis\u00E9","AboutPage.TrustworthyDescription":"Effectuez vos t\u00E9l\u00E9chargements en toute s\u00E9curit\u00E9 avec des applications v\u00E9rifi\u00E9es pour des installations en toute confiance","AboutPage.CertificationTitle":"Processus de v\u00E9rification strict","AboutPage.CertificationDescription":"Toutes les applications sont analys\u00E9es \u00E0 la recherche de programmes malveillants et de probl\u00E8mes de s\u00E9curit\u00E9 connus. Nous v\u00E9rifions \u00E9galement la compatibilit\u00E9 pour vous avant que vous obteniez l\u2019application.","AboutPage.FamilySafetyTitle":"Contr\u00F4le parental","AboutPage.FamilySafetyDescription":"Cr\u00E9ez un environnement num\u00E9rique plus s\u00E9curitaire pour les enfants et les adolescents, avec des protections \u00E0 l\u2019achat et des contr\u00F4les pour les applications et les jeux en fonction de l\u2019\u00E2ge.","AboutPage.TrustedPaymentTitle":"Transactions s\u00E9curis\u00E9es","AboutPage.TrustedPaymentDescription":"S\u00E9curisez vos transactions gr\u00E2ce \u00E0 des moyens de paiement et de r\u00E8glement fiables, tout en prot\u00E9geant vos ressources.","AboutPage.ExperienceTitle":"Exp\u00E9rience transparente sur Windows","AboutPage.ExperienceDescription":"Installation simple et paiement rapide sur tous les appareils Microsoft","AboutPage.ConnectedAccount":"Vos applications sur tous vos appareils","AboutPage.ConnectedAccountDescription":"Les achats et t\u00E9l\u00E9chargements d\u0027applications ou de jeux depuis le Store seront li\u00E9s \u00E0 votre compte Microsoft. Ainsi, lorsque vous acqu\u00E9rez un produit sur un appareil, vous pourrez le restaurer sur vos autres appareils sans frais suppl\u00E9mentaires.","AboutPage.PlayAnywhere":"Jouer n\u2019importe o\u00F9","AboutPage.PlayAnywhereDescription":"Les jeux participants achet\u00E9s aupr\u00E8s du Microsoft Store sur votre ordinateur personnel peuvent \u00EAtre install\u00E9s sur votre Xbox sans frais suppl\u00E9mentaires. Et l\u2019inverse est \u00E9galement vrai\u00A0: les jeux participants achet\u00E9s sur votre console Xbox peuvent \u00EAtre install\u00E9s sur votre ordinateur personnel.","AboutPage.EfficientUpdates":"Mises \u00E0 jour efficaces","AboutPage.EfficientUpdatesDescription":"Le Microsoft\u00A0Store et Windows fonctionnent ensemble pour garantir que les applications du Store re\u00E7oivent efficacement les mises \u00E0 jour en arri\u00E8re-plan.","AboutPage.DiscoverTitle":"D\u00E9couvrir","AboutPage.DiscoverDescription":"Regarder des \u00E9missions \u00E0 partir de votre application de diffusion en continu favorite, cr\u00E9er des images num\u00E9riques avec un logiciel artistique ou travailler avec de puissants outils de productivit\u00E9","AboutPage.Description":"Retrouvez vos applications pr\u00E9f\u00E9r\u00E9es. D\u00E9tendez-vous et lib\u00E9rez votre cr\u00E9ativit\u00E9 et votre productivit\u00E9.","AboutPage.Banner.Title":"Tout le n\u00E9cessaire, o\u00F9 vous voulez","AboutPage.Banner.ToStoreAppLabel":"Explorer d\u00E8s maintenant","AboutPage.MicrosoftStoreTitle":"Application Microsoft Store","AboutPage.MicrosoftStoreDescription":"Obtenez l\u2019application Microsoft Store pour une meilleure exp\u00E9rience de d\u00E9couverte et de mise \u00E0 jour des applications et des jeux sur Windows.","AboutPage.MicrosoftStoreLogoAlt":"Logo Microsoft Store","AboutPage.DownloadStoreButton":"T\u00E9l\u00E9chargez l\u2019application Store","AboutPage.GetStoreAppButton":"Obtenez l\u2019application Microsoft Store","AboutPage.NoStoreQuestion":"Vous n\u2019avez pas l\u2019appli Microsoft\u00A0Store sur votre appareil?","AboutPage.DownloadStorePromptLine1":"Si vous n\u2019avez pas l\u2019application Microsoft Store sur votre p\u00E9riph\u00E9rique,","AboutPage.DownloadStorePromptLine2":"cliquez sur {0} pour le t\u00E9l\u00E9charger maintenant.","AboutPage.DownloadStoreLink":"ici","AboutPage.SeamlessExperience":"sur vos appareils Windows","AboutPage.TrustedDownload":"T\u00E9l\u00E9chargements de confiance","AboutPage.AIIntegrated":"IA int\u00E9gr\u00E9e","AboutPage.AutomaticUpdates":"Mise \u00E0 jour automatique","AboutPage.TrustedDownloadText":"S\u00E9curis\u00E9","AboutPage.AIIntegratedText":"Copilot","AgeVerification.MatureContentSignInRestriction":"Connectez-vous pour afficher ce contenu","AgeVerification.MatureContentSignInSubtitle":"Nous devons v\u00E9rifier votre \u00E2ge pour nous assurer que ce contenu est adapt\u00E9 \u00E0 l\u2019\u00E2ge.","AgeVerification.MatureContentSignInButton":"Se connecter","AgeVerification.MatureContentUnverifiedRestriction":"V\u00E9rifiez votre \u00E2ge pour afficher ce contenu","AgeVerification.MatureContentUnverifiedSubtitle":"Votre compte n\u00E9cessite une v\u00E9rification de l\u2019\u00E2ge avant d\u2019afficher du contenu \u00E0 restriction d\u2019\u00E2ge.","AgeVerification.MatureContentUnverifiedButton":"V\u00E9rifier","AgeVerification.MatureContentRestriction":"Votre compte ne r\u00E9pond pas aux exigences d\u2019\u00E2ge minimum requis pour afficher ce contenu.","BuyBox.Tooltip.SignInRequired":"Vous devez vous connecter pour obtenir cette appli.","BuyBox.Tooltip.AgeBlocked":"Votre compte ne r\u00E9pond pas aux exigences d\u2019\u00E2ge pour ce produit.","BuyBox.Tooltip.VerifyRequired":"Vous devez v\u00E9rifier votre \u00E2ge pour obtenir cette appli.","AlertService.Retry":"R\u00E9essayer","AlertService.SwitchAccount":"Changer de compte","AuthService.SignInError":"Nous avons rencontr\u00E9 une erreur. Veuillez r\u00E9essayer.","AuthService.PopupBlockedError":"Assurez-vous que votre bloqueur de fen\u00EAtres publicitaires est d\u00E9sactiv\u00E9 sur ce site pour vous connecter.","AuthRedirect.Title":"D\u00E9connect\u00E9","AuthRedirect.Description":"Vous \u00EAtes maintenant d\u00E9connect\u00E9.","BadgePage.AppID.Header":"ID de l\u2019application","BadgePage.AppID.Invalid.Tooltip":"L\u2019ID de produit doit comporter 12\u00A0caract\u00E8res, sauf si l\u2019ID commence par XP, auquel cas il doit comporter 14\u00A0caract\u00E8res.","BadgePage.AppID.Tooltip":"L\u0027identifiant de votre appli. Vous pouvez le trouver dans l\u2019Espace partenaires Microsoft ou \u00E0 la fin de l\u0027URL de votre appli sur ce site, par ex. https://applis.microsoft.com/detail/9MV0B5HZVK9Z","BadgePage.AutoLaunch.Header":"Lancement automatique","BadgePage.AutoLaunch.Tooltip":"Si le mode de lancement est complet et que le lancement automatique est activ\u00E9, cliquez sur le badge ouvrira automatiquement l\u2019application Store.","BadgePage.BadgeText":"T\u00E9l\u00E9charger \u00E0 partir de Microsoft Store","BadgePage.ButtonAriaLabel":"Bouton {0}","BadgePage.CID.Header":"ID de campagne","BadgePage.CID.Tooltip":"Code de campagne de votre application. Vous trouverez ceci dans Microsoft Espace partenaires.","BadgePage.Description":"La pastille d\u2019application Microsoft Store est le meilleur moyen pour vous d\u2019afficher, de diriger et de suivre le trafic de vos ressources vers la Description dans Microsoft Store.","BadgePage.UpdateDescription":"MISE \u00C0 JOUR\u00A0: les badges qui n\u2019ont pas de surface de lancement configur\u00E9e sont d\u00E9sormais d\u00E9finis par d\u00E9faut sur le type de t\u00E9l\u00E9chargement direct. L\u2019option de lancement automatique ne sera pas disponible pour les t\u00E9l\u00E9chargements directs. Les badges JavaScript existants qui utilisaient le type \u00AB\u00A0fen\u00EAtre contextuelle\u00A0\u00BB sont \u00E9galement d\u00E9finis par d\u00E9faut sur le type de t\u00E9l\u00E9chargement direct.","BadgePage.UpdatePopupDescription":"Pour continuer \u00E0 utiliser le Store popup, g\u00E9n\u00E9rez \u00E0 nouveau le badge et utilisez le nouveau code.","BadgePage.Preview.Tab":"Aper\u00E7u","BadgePage.CodeSnippet.Tab":"Extrait de code","BadgePage.Optional.Text":"(Facultatif)","BadgePage.Interaction.Header":"Animations interactives","BadgePage.Interaction.Tooltip":"L\u2019animation du badge sur les \u00E9tats de survol et d\u2019appui.","BadgePage.Language.Header":"Langue","BadgePage.StaticLanguage.Tooltip":"Choisissez une langue pour afficher le badge.","BadgePage.WebComponentLanguage.Tooltip":"La d\u00E9tection automatique (recommand\u00E9) rend le badge dans la langue du navigateur de l\u0027utilisateur. Vous pouvez \u00E9galement choisir une langue pour toujours afficher le badge dans cette langue.","BadgePage.Launch.Header":"Mode de lancement","BadgePage.Launch.Tooltip":"Mode de lancement de votre application lorsque les utilisateurs cliquent sur votre badge. Le mode direct t\u00E9l\u00E9charge l\u2019ex\u00E9cutable du programme d\u2019installation de votre appli et est le mode par d\u00E9faut. Le mode complet ouvre la page produit de votre application dans l\u2019application Store.","BadgePage.WebComponent.Tab":"Composant Web","BadgePage.TabAriaLabel":"{0} onglet","BadgePage.TabSelectedAriaLabel":"Onglet {0} s\u00E9lectionn\u00E9","BadgePage.Theme.Header":"Th\u00E8me","BadgePage.StaticTheme.Tooltip":"Th\u00E8me de badge \u00E0 utiliser. Le guide consiste \u00E0 choisir des arri\u00E8re-plans sombres et inversement.","BadgePage.WebComponentTheme.Tooltip":"La d\u00E9tection automatique d\u00E9tecte le th\u00E8me de l\u2019utilisateur et affiche le th\u00E8me de badge correspondant.","BadgePage.Title":"Cr\u00E9er votre badge d\u2019application","BadgePage.Tooltip":"Info-bulle.","BadgePage.Guidelines.Tooltip":"Instructions","BadgePage.False.Option":"Faux","BadgePage.True.Option":"Vrai","BadgePage.Direct.Option":"Direct","BadgePage.Full.Option":"Complet","BadgePage.None.Option":"Aucun","BadgePage.Dark.Option":"Sombre","BadgePage.Light.Option":"Clair","BadgePage.Off.Option":"D\u00E9sactiv\u00E9","BadgePage.On.Option":"Activ\u00E9","BadgePage.AutoDetect.Option":"D\u00E9tection automatique","BadgePage.GenerateBadge":"G\u00E9n\u00E9rer votre badge","BadgePage.CopiedClipboard":"Le lien a \u00E9t\u00E9 copi\u00E9 dans le Presse-papiers.","BadgePage.StaticBadge.Title":"Badge statique","BadgePage.StaticBadge.SimpleDescription":"Un badge simple et l\u00E9ger utilisant une image et un lien standards.","BadgePage.StaticBadge.Description":"Ce badge est id\u00E9al pour les fichiers README, les sites de documentation, les environnements avec des politiques de s\u00E9curit\u00E9 du contenu, ou partout o\u00F9 les scripts externes sont restreints.\u00A0","BadgePage.WebComponentBadge.Title":"Badge composant Web","BadgePage.WebComponentBadge.SimpleDescription":"Un badge dynamique et interactif con\u00E7u comme un composant Web.","BadgePage.WebComponentBadge.Description":"Ce badge est bas\u00E9 sur JavaScript et offre des fonctionnalit\u00E9s modernes, notamment la d\u00E9tection automatique des param\u00E8tres r\u00E9gionaux et des th\u00E8mes, ainsi qu\u2019une animation par pointage r\u00E9gulier. Choisissez cette option lorsque vous souhaitez b\u00E9n\u00E9ficier d\u2019une exp\u00E9rience optimale et personnalis\u00E9e pour vos utilisateurs.","BadgePage.GetStarted.Title":"D\u00E9marrer","BadgePage.GetStarted.Description":"Suivez ces \u00E9tapes pour g\u00E9n\u00E9rer votre badge et l\u2019ajouter \u00E0 votre site web.","BadgePage.GetStarted.Step1.Title":"Choisir un type de badge","BadgePage.GetStarted.Step1.Description":"Choisissez entre un composant web ou un badge statique. Si vous n\u2019\u00EAtes pas s\u00FBr, le badge statique est un bon choix.","BadgePage.GetStarted.Step2.Title":"Saisir votre ID d\u2019application","BadgePage.GetStarted.Step2.Description":"Collez votre ID d\u2019application de 12 caract\u00E8res (trouv\u00E9 dans votre tableau de bord Espace partenaires) dans la zone de texte.","BadgePage.GetStarted.Step3.Title":"S\u00E9lectionner des propri\u00E9t\u00E9s","BadgePage.GetStarted.Step3.Description":"Personnaliser la langue, le th\u00E8me et les cibles de lancement, ou ajouter un ID de campagne pour suivre les performances","BadgePage.GetStarted.Step4.Title":"Copier le code","BadgePage.GetStarted.Step4.Description":"Cliquez sur \u00AB G\u00E9n\u00E9rer votre badge \u00BB et collez l\u2019extrait directement dans le code de votre site web.","BadgePage.Guidelines.Title":"Lignes directrices et meilleures pratiques","BadgePage.Guidelines.Description":"Suivez ces bonnes pratiques pour optimiser vos taux de conversion et maintenir la coh\u00E9rence de la marque.","BadgePage.Guidelines.KeepItClear.Title":"Rester clair(e)","BadgePage.Guidelines.KeepItClear.Description":"Maintenir un espacement standard autour du badge. Ne pas le surcharger avec d\u2019autres textes ou \u00E9l\u00E9ments graphiques.","BadgePage.Guidelines.PlaceProminent.Title":"Le placer bien en vue","BadgePage.Guidelines.PlaceProminent.Description":"Pour obtenir les meilleurs taux de clics, placez le badge \u00AB\u00A0au-dessus de la ligne de flottaison\u00A0\u00BB sur votre page d\u2019accueil, ou directement \u00E0 c\u00F4t\u00E9 de la liste des fonctionnalit\u00E9s principales de votre appli.","BadgePage.Guidelines.DontAlter.Title":"Ne pas modifier l\u2019illustration","BadgePage.Guidelines.DontAlter.Description":"Utiliser le code g\u00E9n\u00E9r\u00E9 tel quel. Ne pas modifier la taille, la couleur ni les graphiques du badge, car cela contrevient aux directives de la marque Microsoft Store.","BadgePage.Guidelines.CampaignId.Title":"Ajouter un ID de campagne pour suivre les performances","BadgePage.Guidelines.CampaignId.Description":"Ajouter un ID de campagne vous permet de suivre les visiteurs et les conversions, ce qui facilite l\u2019exp\u00E9rimentation de diff\u00E9rents emplacements. Apr\u00E8s tout, on ne peut pas am\u00E9liorer ce que l\u2019on ne mesure pas!","BadgePage.Guidelines.DownloadLink":"T\u00E9l\u00E9chargez les instructions compl\u00E8tes (PDF).","BadgePage.FAQ.Title":"FAQ","BadgePage.FAQ.FindAppId.Question":"O\u00F9 puis-je trouver mon ID d\u2019application de 12 caract\u00E8res (ID de produit)?","BadgePage.FAQ.FindAppId.Answer1":"Votre ID d\u2019appli (\u00E9galement appel\u00E9 ID de produit) est un code alphanum\u00E9rique unique de 12\u00A0caract\u00E8res attribu\u00E9 \u00E0 votre application. Vous pouvez le trouver dans votre tableau de bord Windows Partner Center. Acc\u00E9dez \u00E0 la page de votre application, s\u00E9lectionnez Gestion des applications \u003E Identit\u00E9 de l\u2019application, puis recherchez la valeur \u00AB\u00A0Store ID\u00A0\u00BB.","BadgePage.FAQ.FindAppId.Answer2":"Vous pouvez \u00E9galement trouver votre application sur applis.microsoft.com. Votre ID d\u2019appli est le code de 12\u00A0caract\u00E8res \u00E0 la fin de l\u2019URL\u00A0: applis.microsoft.com/detail/\u003CAppID\u003E.","BadgePage.FAQ.TrackDownloads.Question":"Comment suivre le nombre de t\u00E9l\u00E9chargements g\u00E9n\u00E9r\u00E9s depuis mon site Web?","BadgePage.FAQ.TrackDownloads.Answer":"Vous pouvez suivre les performances de votre badge en ajoutant un ID de campagne (cid) \u00E0 votre lien de badge. Lorsque vous g\u00E9n\u00E9rez votre badge ci-dessus, saisissez un nom de campagne personnalis\u00E9 (p. ex. \u00AB\u00A0fooapp_website\u00A0\u00BB). Vous pouvez ensuite consulter les taux de clics publicitaires et les donn\u00E9es de conversion li\u00E9s \u00E0 cette campagne sp\u00E9cifique dans votre Rapport d\u2019acquisition de l\u2019Espace partenaires.","BadgePage.FAQ.WhichBadgeType.Question":"Quel type de badge dois-je choisir\u00A0: Statique ou Composant Web?","BadgePage.FAQ.WhichBadgeType.Answer1":"Choisissez le composant web pour b\u00E9n\u00E9ficier d\u2019une exp\u00E9rience utilisateur optimale sur les sites web modernes. Il d\u00E9tecte automatiquement la langue syst\u00E8me de l\u2019utilisateur, met \u00E0 jour pour correspondre \u00E0 la langue de conception actuelle de Microsoft et fournit des animations par pointage r\u00E9gulier.","BadgePage.FAQ.WhichBadgeType.Answer2":"Choisissez le badge Statique si votre plateforme restreint JavaScript (comme les README de GitHub, WordPress sans JS personnalis\u00E9 ou les environnements avec une politique de s\u00E9curit\u00E9 de contenu stricte).","BadgePage.FAQ.UpdateBadge.Question":"Dois-je mettre \u00E0 jour mon badge si le Microsoft Store change de marque?","BadgePage.FAQ.UpdateBadge.Answer":"Si vous utilisez les badges g\u00E9n\u00E9r\u00E9s \u00E0 partir de cette page, non. Les ressources sont h\u00E9berg\u00E9es par Microsoft et mettront automatiquement \u00E0 jour votre badge pour refl\u00E9ter les modifications ult\u00E9rieures apport\u00E9es \u00E0 la marque ou \u00E0 la conception.","BadgePage.FAQ.ResizeBadge.Question":"Puis-je redimensionner le badge pour qu\u2019il s\u2019adapte au design de mon site Web?","BadgePage.FAQ.ResizeBadge.Answer":"Le badge du composant Web est naturellement r\u00E9actif et s\u2019adapte correctement. Si vous utilisez l\u2019image statique, vous pouvez la redimensionner avec du CSS (par exemple, en ajustant la largeur maximale), mais vous devez conserver le rapport d\u2019aspect d\u2019origine. Ne jamais \u00E9tirer, d\u00E9former ni rogner l\u2019image.","BadgePage.FAQ.DarkMode.Question":"Le badge prend-il en charge le mode sombre?","BadgePage.FAQ.DarkMode.Answer":"Oui. Le badge Composant Web peut d\u00E9tecter automatiquement le th\u00E8me syst\u00E8me de l\u2019utilisateur(-trice) ou le th\u00E8me CSS de votre site Web et afficher une variante sombre ou claire. Vous pouvez aussi le forcer \u00E0 s\u2019afficher toujours en mode sombre ou clair \u00E0 l\u2019aide des outils de g\u00E9n\u00E9ration ci-dessus.","BadgePage.SideNav.GetStarted":"D\u00E9marrer","BadgePage.SideNav.BuildYourBadge":"D\u00E9velopper votre badge","BadgePage.SideNav.StaticBadge":"Badge statique","BadgePage.SideNav.WebComponentBadge":"Badge composant Web","BadgePage.SideNav.Guidelines":"Instructions","BadgePage.SideNav.FAQ":"FAQ","Common.CollectionsTitle":"Collections","CollectionReel.PlayButton":"Lire l\u2019animation sur le reel de collection","CollectionReel.PauseButton":"Suspendre l\u2019animation sur le reel de collection","Common.PageTitle":"{0} \u2013 Microsoft Apps","Common.PageAppsTitle":"{0} - T\u00E9l\u00E9charger et installer sur Windows | Microsoft Store","Common.PageAppsFreeTitle":"{0}\u00A0: t\u00E9l\u00E9chargement et installation gratuits sous Windows | Microsoft Store","Common.PageGameTitle":"{0} - T\u00E9l\u00E9charger et lire sur Windows | Microsoft Store","Common.PageGameFreeTitle":"{0} - T\u00E9l\u00E9chargement et lecture gratuits sur Windows | Microsoft Store","MsStoreDetails.PageTitle":"T\u00E9l\u00E9charger et installer l\u2019application Microsoft Store sur Windows","Common.ScrollLeft.ButtonTitle":"Faire d\u00E9filer vers la gauche","Common.ScrollRight.ButtonTitle":"Faire d\u00E9filer vers la droite","Common.ScrollToTop.ButtonTitle":"Faire d\u00E9filer vers le haut","Common.SeeAll":"Tout afficher","Common.SeeAllTitle":"Afficher tout {0}. Utiliser les touches de direction pour parcourir les \u00E9l\u00E9ments","Collection.LoadMore":"Afficher plus","Common.SeeDetails":"Afficher les d\u00E9tails","Common.AdBadge":"Publicit\u00E9","Common.MenuItemSelected":"{0} s\u00E9lectionn\u00E9(e)","Common.SpotlightCa